@page
@model Group3_SE1902_PRN222_LibraryManagement.Pages.Admin.BookManagement.DetailsModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chi tiết sách";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h4 m-0 text-primary"><i class="bi bi-info-circle me-2"></i>Thông tin chi tiết sách</h2>
        <a asp-page="./Index" class="btn btn-outline-secondary btn-sm shadow-sm">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách
        </a>
    </div>

    <div class="row bg-white p-4 shadow-sm rounded border">
        <div class="col-md-4 text-center border-end">
            <div class="p-2">
                @if (!string.IsNullOrEmpty(Model.Book.ImageUrl))
                {
                    <img src="@Model.Book.ImageUrl" alt="@Model.Book.Title"
                         class="img-fluid rounded shadow-sm border"
                         style="max-height: 400px; width: 100%; object-fit: contain;"
                         onerror="this.src='https://via.placeholder.com/300x450?text=No+Cover'" />
                }
                else
                {
                    <img src="https://via.placeholder.com/300x450?text=No+Cover" class="img-fluid rounded shadow-sm border" />
                }
            </div>
            <div class="mt-3">
                <span class="badge bg-light text-dark border p-2 w-100">
                    <i class="bi bi-barcode me-1"></i> ISBN: @Model.Book.Isbn
                </span>
            </div>
        </div>

        <div class="col-md-8 ps-md-5">
            <div class="mb-3">
                <h3 class="fw-bold text-dark mb-1">@Model.Book.Title</h3>
                <p class="text-muted fs-5 mb-0">Tác giả: <span class="text-primary fw-bold">@Model.Book.Author</span></p>
            </div>

            <hr class="my-4" />

            <dl class="row fs-6">
                <dt class="col-sm-4 text-muted fw-normal mb-3">Nhà xuất bản:</dt>
                <dd class="col-sm-8 fw-bold mb-3">@Model.Book.Publisher</dd>

                <dt class="col-sm-4 text-muted fw-normal mb-3">Năm xuất bản:</dt>
                <dd class="col-sm-8 mb-3">@Model.Book.PublishYear</dd>

                <dt class="col-sm-4 text-muted fw-normal mb-3">Thể loại:</dt>
                <dd class="col-sm-8 mb-3">
                    <span class="badge bg-success bg-opacity-10 text-success border border-success px-3 py-2">
                        <i class="bi bi-tag-fill me-1"></i>
                        @(Model.Book.Category?.CategoryName ?? "Chưa xác định")
                    </span>
                </dd>

                <dt class="col-sm-4 text-muted fw-normal mb-3">Số lượng trong kho:</dt>
                <dd class="col-sm-8 mb-3">
                    <span class="fw-bold @(Model.Book.TotalQuantity > 0 ? "text-dark" : "text-danger")">
                        @Model.Book.TotalQuantity cuốn
                    </span>
                </dd>

                <dt class="col-sm-4 text-muted fw-normal mb-3">Mô tả nội dung:</dt>
                <dd class="col-sm-8 mb-3">
                    @* Xóa bỏ giới hạn chiều cao hoặc text-truncate nếu có *@
                    <div class="text-dark lh-lg" style="white-space: pre-wrap; text-align: justify; word-break: break-word;">
                        @Model.Book.Description
                    </div>
                </dd>
            </dl>

            <div class="mt-4 pt-3 border-top">
                <a asp-page="./Edit" asp-route-id="@Model.Book.BookId" class="btn btn-warning px-4 shadow-sm text-dark fw-bold">
                    <i class="bi bi-pencil-square me-1"></i> Chỉnh sửa thông tin
                </a>
            </div>
        </div>
    </div>
</div>