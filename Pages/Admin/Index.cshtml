@page
@model Group3_SE1902_PRN222_LibraryManagement.Pages.Admin.IndexModel
@{
    Layout = "_Layout";
}

<style>
    .sidebar {
        position: fixed;
        top: 0;
        left: 0;
        height: 100vh;
        width: 260px;
        background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
        transition: all 0.3s ease;
        z-index: 1000;
        overflow-x: hidden;
    }
    
    .sidebar.collapsed {
        width: 70px;
    }
    
    .sidebar.collapsed .sidebar-text {
        display: none;
    }
    
    .sidebar.collapsed .nav-link {
        justify-content: center;
        padding: 15px;
    }
    
    .sidebar.collapsed h4 {
        font-size: 0;
    }
    
    .sidebar.collapsed h4::first-letter {
        font-size: 1.5rem;
    }
    
    .toggle-btn {
        position: fixed;
        top: 15px;
        left: 10px;
        z-index: 1001;
        background: #4D96FF;
        border: none;
        color: white;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        cursor: pointer;
        transition: all 0.3s ease;
    }
    
    .toggle-btn:hover {
        background: #3d8bff;
        transform: scale(1.1);
    }
    
    .main-content {
        margin-left: 260px;
        transition: margin-left 0.3s ease;
        padding: 20px;
    }
    
    .main-content.expanded {
        margin-left: 70px;
    }
    
    .nav-link {
        color: rgba(255,255,255,0.8);
        padding: 12px 20px;
        border-radius: 8px;
        margin: 4px 12px;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        gap: 12px;
    }
    
    .nav-link:hover {
        background: rgba(255,255,255,0.1);
        color: white;
        transform: translateX(5px);
    }
    
    .nav-link.active {
        background: linear-gradient(90deg, #4D96FF, #6BCB77);
        color: white;
    }
    
    .stat-card {
        border: none;
        border-radius: 16px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    
    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }
    
    .stat-card .card-body {
        padding: 20px;
    }
    
    .stat-card h2 {
        font-size: 2.5rem;
        font-weight: 700;
    }
</style>

<button class="toggle-btn" onclick="toggleSidebar()">
    <span id="toggle-icon">☰</span>
</button>

<div class="sidebar" id="sidebar">
    <h4 class="mb-4 text-center text-warning py-3" style="border-bottom: 1px solid rgba(255,255,255,0.1);">
        📚 Thư Viện Nhí
    </h4>
    <ul class="nav flex-column mt-3">
        <li class="nav-item">
            <a class="nav-link active" href="#">
                <span style="font-size: 1.2rem;">📊</span> <span class="sidebar-text">Dashboard</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="#">
                <span style="font-size: 1.2rem;">📖</span> <span class="sidebar-text">Quản lý sách</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="#">
                <span style="font-size: 1.2rem;">👥</span> <span class="sidebar-text">Quản lý người dùng</span>
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" href="#">
                <span style="font-size: 1.2rem;">📋</span> <span class="sidebar-text">Quản lý mượn trả</span>
            </a>
        </li>
        <li class="nav-item mt-auto" style="position: absolute; bottom: 20px; width: 100%;">
            <a class="nav-link" href="/Login">
                <span style="font-size: 1.2rem;">🚪</span> <span class="sidebar-text">Đăng xuất</span>
            </a>
        </li>
    </ul>
</div>

<div class="main-content" id="mainContent">
    <h2 class="mb-4" style="color: #1a1a2e; font-weight: 600;">Dashboard Admin</h2>
    
    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card stat-card bg-primary text-white">
                <div class="card-body">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <div>
                            <small style="opacity: 0.8;">Tổng sách</small>
                            <h2 class="mb-0">@Model.TotalBooks</h2>
                        </div>
                        <span style="font-size: 2.5rem;">📚</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card bg-success text-white">
                <div class="card-body">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <div>
                            <small style="opacity: 0.8;">Sách đang mượn</small>
                            <h2 class="mb-0">@Model.BooksBorrowed</h2>
                        </div>
                        <span style="font-size: 2.5rem;">📖</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card bg-warning text-dark">
                <div class="card-body">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <div>
                            <small style="opacity: 0.7;">Tổng người dùng</small>
                            <h2 class="mb-0">@Model.TotalUsers</h2>
                        </div>
                        <span style="font-size: 2.5rem;">👥</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card stat-card bg-info text-white">
                <div class="card-body">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <div>
                            <small style="opacity: 0.8;">Yêu cầu mượn</small>
                            <h2 class="mb-0">@Model.PendingRequests</h2>
                        </div>
                        <span style="font-size: 2.5rem;">📝</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Books Table -->
    <div class="card mb-4" style="border: none; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
        <div class="card-header bg-white text-white" style="border-radius: 16px 16px 0 0; border-bottom: 2px solid #4D96FF;">
            <h5 class="mb-0" style="color: #1a1a2e;">📖 Danh sách sách</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped table-hover mb-0" style="border-radius: 0 0 16px 16px;">
                <thead class="table-light" style="background: #f8f9fa;">
                    <tr>
                        <th style="padding: 15px;">ID</th>
                        <th style="padding: 15px;">Tiêu đề</th>
                        <th style="padding: 15px;">Tác giả</th>
                        <th style="padding: 15px;">Thể loại</th>
                        <th style="padding: 15px;">Số lượng</th>
                        <th style="padding: 15px;">Đã mượn</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var book in Model.Books)
                    {
                        <tr style="transition: background 0.2s;">
                            <td style="padding: 15px;">@book.BookID</td>
                            <td style="padding: 15px;"><strong>@book.Title</strong></td>
                            <td style="padding: 15px;">@book.Author</td>
                            <td style="padding: 15px;"><span class="badge bg-info">@book.CategoryName</span></td>
                            <td style="padding: 15px;">@book.TotalQuantity</td>
                            <td style="padding: 15px;">
                                @if (book.BorrowedCount > 0)
                                {
                                    <span class="badge bg-success">@book.BorrowedCount</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">0</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Favorite Books -->
    <div class="row">
        <div class="col-md-6">
            <div class="card" style="border: none; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
                <div class="card-header bg-white" style="border-radius: 16px 16px 0 0; border-bottom: 2px solid #FFD93D;">
                    <h5 class="mb-0" style="color: #1a1a2e;">⭐ Sách được yêu thích nhất</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0" style="border-radius: 0 0 16px 16px;">
                        <thead>
                            <tr style="background: #FFFDF5;">
                                <th style="padding: 12px;">STT</th>
                                <th style="padding: 12px;">Tiêu đề</th>
                                <th style="padding: 12px;">Lượt thích</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var book in Model.TopFavoriteBooks)
                            {
                                <tr>
                                    <td style="padding: 12px;"><span class="badge bg-warning text-dark">@book.RowNum</span></td>
                                    <td style="padding: 12px;">@book.Title</td>
                                    <td style="padding: 12px;"><span class="badge bg-warning text-dark">❤️ @book.FavoriteCount</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card" style="border: none; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,0.08);">
                <div class="card-header bg-white" style="border-radius: 16px 16px 0 0; border-bottom: 2px solid #6BCB77;">
                    <h5 class="mb-0" style="color: #1a1a2e;">📚 Sách được mượn nhiều nhất</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0" style="border-radius: 0 0 16px 16px;">
                        <thead>
                            <tr style="background: #F0FFF4;">
                                <th style="padding: 12px;">STT</th>
                                <th style="padding: 12px;">Tiêu đề</th>
                                <th style="padding: 12px;">Lượt mượn</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var book in Model.TopBorrowedBooks)
                            {
                                <tr>
                                    <td style="padding: 12px;"><span class="badge bg-success">@book.RowNum</span></td>
                                    <td style="padding: 12px;">@book.Title</td>
                                    <td style="padding: 12px;"><span class="badge bg-success">📖 @book.BorrowCount</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleSidebar() {
        var sidebar = document.getElementById('sidebar');
        var mainContent = document.getElementById('mainContent');
        var toggleIcon = document.getElementById('toggle-icon');
        
        sidebar.classList.toggle('collapsed');
        mainContent.classList.toggle('expanded');
        
        if (sidebar.classList.contains('collapsed')) {
            toggleIcon.textContent = '☰';
        } else {
            toggleIcon.textContent = '✕';
        }
    }
</script>
