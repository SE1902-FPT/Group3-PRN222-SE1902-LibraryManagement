@page
@model Group3_SE1902_PRN222_LibraryManagement.Pages.Admin.UserManagement.CreateModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Tạo người dùng mới";
}

<div class="container-fluid">
    <div class="mb-4">
        <a asp-page="./Index" class="text-decoration-none text-muted small">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách
        </a>
    </div>

    <div class="row">
        <div class="col-md-8 mx-auto">
            <form method="post">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3">
                        <h5 class="text-primary m-0 fw-bold">Thêm người dùng mới</h5>
                    </div>
                    <div class="card-body p-4">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <h6 class="text-muted fw-bold mb-3 border-bottom pb-2 small">THÔNG TIN TÀI KHOẢN</h6>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="User.FullName" class="form-label fw-bold small">Họ và tên</label>
                                <input asp-for="User.FullName" class="form-control" placeholder="Nguyễn Văn A" required />
                                <span asp-validation-for="User.FullName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="User.Email" class="form-label fw-bold small">Email</label>
                                <input asp-for="User.Email" class="form-control" placeholder="example@fpt.edu.vn" required />
                                <span asp-validation-for="User.Email" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Mật khẩu mặc định</label>
                                <input asp-for="RawPassword" class="form-control" type="text" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="User.RoleId" class="form-label fw-bold small">Vai trò</label>
                                <select asp-for="User.RoleId" class="form-select border-primary" id="roleSelect" asp-items="ViewBag.RoleId" required>
                                    <option value="">-- Chọn vai trò --</option>
                                </select>
                            </div>
                        </div>

                        <div id="extraInfo" style="display: none;">
                            <h6 class="text-primary fw-bold mb-3 mt-4 border-bottom pb-2 small">THÔNG TIN CHI TIẾT VAI TRÒ</h6>

                            <div id="classSection" class="mb-3" style="display: none;">
                                <label class="form-label fw-bold small">Lớp học phụ trách/theo học</label>
                                <select asp-for="SelectedClassId" class="form-select" asp-items="ViewBag.ClassId">
                                    <option value="">-- Chọn lớp học --</option>
                                </select>
                            </div>

                            <div id="parentSection" style="display: none;">
                                <div class="row mb-3">
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold small">Mối quan hệ</label>
                                        <input asp-for="Relationship" class="form-control" placeholder="Bố/Mẹ/Anh..." />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold small">Số điện thoại</label>
                                        <input asp-for="ParentPhone" class="form-control" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold small">Địa chỉ</label>
                                        <input asp-for="ParentAddress" class="form-control" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4 pt-3 border-top">
                            <button type="submit" class="btn btn-primary px-5 shadow-sm">Xác nhận tạo</button>
                            <a asp-page="Index" class="btn btn-outline-secondary ms-2">Hủy</a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            $('#roleSelect').on('change', function () {
                var roleText = $(this).find("option:selected").text().trim();

                $('#extraInfo').hide();
                $('#classSection').hide();
                $('#parentSection').hide();

                if (roleText === "Student" || roleText === "Teacher") {
                    $('#extraInfo').fadeIn();
                    $('#classSection').show();
                } else if (roleText === "Parent") {
                    $('#extraInfo').fadeIn();
                    $('#parentSection').show();
                }
            });
        });
    </script>
}