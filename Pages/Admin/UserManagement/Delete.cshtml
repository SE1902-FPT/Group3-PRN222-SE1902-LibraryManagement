@page
@model Group3_SE1902_PRN222_LibraryManagement.Pages.Admin.UserManagement.DeleteModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Xác nhận xóa người dùng";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-6 mx-auto">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white py-3">
                    <h5 class="m-0 fw-bold">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> Cảnh báo xóa người dùng
                    </h5>
                </div>
                <div class="card-body p-4 text-center">
                    <div class="mb-4">
                        <i class="bi bi-person-x text-danger" style="font-size: 4rem;"></i>
                    </div>

                    <h4 class="fw-bold">Bạn có chắc chắn muốn xóa?</h4>
                    <p class="text-muted">
                        Hành động này sẽ xóa người dùng <strong>@Model.User.FullName</strong> (@Model.User.Email).
                        <br />
                        <span class="text-danger small italic">* Các liên kết lớp học và phụ huynh liên quan sẽ bị gỡ bỏ.</span>
                    </p>

                    <hr />

                    <form method="post">
                        <input type="hidden" asp-for="User.UserId" />

                        <div class="d-flex justify-content-center gap-2">
                            <button type="submit" class="btn btn-danger px-4 shadow-sm">
                                <i class="bi bi-trash me-1"></i> Xác nhận xóa
                            </button>
                            <a asp-page="./Index" class="btn btn-light border px-4">
                                Hủy bỏ
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger mt-3 shadow-sm">
                    <i class="bi bi-bug me-2"></i> @TempData["ErrorMessage"]
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
}