@page
@model Group3_SE1902_PRN222_LibraryManagement.Pages.Admin.UserManagement.EditModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chỉnh sửa người dùng";
}

<div class="container-fluid">
    <div class="mb-4">
        <a asp-page="./Index" class="text-decoration-none text-muted small">
            <i class="bi bi-arrow-left"></i> Quay lại danh sách
        </a>
    </div>

    <div class="row">
        <div class="col-xl-9 col-lg-10 mx-auto">
            <form method="post">
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-white py-3 border-bottom">
                        <h5 class="m-0 text-primary fw-bold">
                            <i class="bi bi-pencil-square me-2"></i>Chỉnh sửa hồ sơ: @Model.User.FullName
                        </h5>
                    </div>

                    <div class="card-body p-4">
                        <div asp-validation-summary="All" class="alert alert-danger mb-3 py-2 small" id="errorSummary"></div>

                        <input type="hidden" asp-for="User.UserId" />
                        <input type="hidden" asp-for="User.PasswordHash" />
                        <input type="hidden" asp-for="User.CreatedAt" />

                        <h6 class="text-muted fw-bold mb-3 border-bottom pb-2 text-uppercase small">Thông tin cơ bản</h6>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="User.FullName" class="form-label fw-bold small">Họ và tên</label>
                                <input asp-for="User.FullName" class="form-control" placeholder="Nhập họ tên..." />
                                <span asp-validation-for="User.FullName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="User.Email" class="form-label fw-bold small">Email</label>
                                <input asp-for="User.Email" class="form-control" placeholder="email@example.com" />
                                <span asp-validation-for="User.Email" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-danger">Mật khẩu mới</label>
                                <input asp-for="NewPassword" class="form-control" type="password" placeholder="Để trống nếu không muốn đổi" />
                                <div class="form-text mt-1 italic" style="font-size: 0.75rem;">Chỉ nhập khi bạn muốn thay đổi mật khẩu cho người dùng này.</div>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="User.Status" class="form-label fw-bold small">Trạng thái tài khoản</label>
                                <select asp-for="User.Status" class="form-select">
                                    <option value="Active">Hoạt động (Active)</option>
                                    <option value="Inactive">Bị khóa (Inactive)</option>
                                </select>
                            </div>
                        </div>

                        <h6 class="text-muted fw-bold mb-3 border-bottom pb-2 text-uppercase small">Vai trò & Liên kết hệ thống</h6>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="User.RoleId" class="form-label fw-bold small">Vai trò người dùng</label>
                                <select asp-for="User.RoleId" class="form-select border-primary shadow-sm" id="roleSelect" asp-items="ViewBag.RoleId"></select>
                            </div>
                        </div>

                        <div id="classSection" class="p-3 bg-light rounded border mb-3" style="display:none;">
                            <label class="form-label fw-bold small"><i class="bi bi-door-open me-1"></i>Lớp học liên kết</label>
                            <select asp-for="SelectedClassId" class="form-select" asp-items="ViewBag.ClassId">
                                <option value="">-- Chọn lớp học --</option>
                            </select>
                            <div class="form-text text-muted" style="font-size: 0.7rem;">Dành cho Giáo viên chủ nhiệm hoặc Sinh viên đang theo học.</div>
                        </div>

                        <div id="parentSection" class="p-3 bg-light rounded border mb-3" style="display:none;">
                            <h6 class="fw-bold text-primary small mb-3"><i class="bi bi-people me-1"></i>Chi tiết phụ huynh - học sinh</h6>
                            <div class="mb-3">
                                <label class="form-label fw-bold small">Phụ huynh của sinh viên:</label>
                                <select asp-for="SelectedStudentId" class="form-select" asp-items="ViewBag.StudentId">
                                    <option value="">-- Chọn sinh viên liên kết --</option>
                                </select>
                            </div>
                            <div class="row">
                                <div class="col-md-4">
                                    <label class="form-label fw-bold small">Quan hệ</label>
                                    <input asp-for="Relationship" class="form-control" placeholder="Cha/Mẹ..." />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold small">Số điện thoại</label>
                                    <input asp-for="ParentPhone" class="form-control" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold small">Địa chỉ</label>
                                    <input asp-for="ParentAddress" class="form-control" />
                                </div>
                            </div>
                        </div>

                        <div class="mt-5 pt-3 border-top d-flex gap-2">
                            <button type="submit" class="btn btn-success px-5 shadow-sm">
                                <i class="bi bi-save me-1"></i> Lưu thay đổi
                            </button>
                            <a asp-page="./Index" class="btn btn-outline-secondary px-4">Hủy bỏ</a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            // Tự động ẩn thông báo lỗi sau 10 giây nếu không có lỗi mới
            if ($("#errorSummary").text().trim() === "") {
                $("#errorSummary").hide();
            }

            function toggleRoleFields() {
                var selectedRole = $("#roleSelect option:selected").text().trim();

                $("#classSection").hide();
                $("#parentSection").hide();

                // Lưu ý: So sánh đúng với text trong bảng Role của bạn
                if (selectedRole === "Student" || selectedRole === "Teacher") {
                    $("#classSection").slideDown(200);
                }
                else if (selectedRole === "Parent") {
                    $("#parentSection").slideDown(200);
                }
            }

            toggleRoleFields();

            $("#roleSelect").on("change", function () {
                toggleRoleFields();
            });
        });
    </script>
}