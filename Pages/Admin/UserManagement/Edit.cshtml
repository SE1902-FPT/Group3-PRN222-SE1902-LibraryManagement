@page
@model Group3_SE1902_PRN222_LibraryManagement.Pages.Admin.UserManagement.EditModel

@{
    ViewData["Title"] = "Edit";
    Layout = "~/Pages/Shared/_AdminLayout.cshtml";
}

<h1>Edit</h1>

<h4>User</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="UserItem.UserId" />
            <div class="form-group">
                <label asp-for="UserItem.FullName" class="control-label"></label>
                <input asp-for="UserItem.FullName" class="form-control" />
                <span asp-validation-for="UserItem.FullName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="UserItem.Email" class="control-label"></label>
                <input asp-for="UserItem.Email" class="form-control" />
                <span asp-validation-for="UserItem.Email" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="UserItem.PasswordHash" class="control-label"></label>
                <input asp-for="UserItem.PasswordHash" class="form-control" />
                <span asp-validation-for="UserItem.PasswordHash" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="UserItem.RoleId" class="control-label"></label>
                <select asp-for="UserItem.RoleId" class="form-control" asp-items="ViewBag.RoleId" ></select>
                <span asp-validation-for="UserItem.RoleId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="UserItem.Status" class="control-label"></label>
                <input asp-for="UserItem.Status" class="form-control" />
                <span asp-validation-for="UserItem.Status" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="UserItem.CreatedAt" class="control-label"></label>
                <input asp-for="UserItem.CreatedAt" class="form-control" />
                <span asp-validation-for="UserItem.CreatedAt" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
