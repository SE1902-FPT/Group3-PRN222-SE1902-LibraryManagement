@page
@model Group3_SE1902_PRN222_LibraryManagement.Pages.Admin.UserManagement.IndexModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý người dùng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 m-0 text-primary"><i class="bi bi-people-fill me-2"></i>Quản lý người dùng</h2>
    <a asp-page="Create" class="btn btn-primary shadow-sm">
        <i class="bi bi-person-plus-fill me-1"></i> Thêm người dùng mới
    </a>
</div>

<div class="card shadow-sm border-0 mb-4 bg-light">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label fw-bold small">Tìm kiếm</label>
                <input type="text" asp-for="SearchString" class="form-control" placeholder="Tên hoặc Email..." />
            </div>
            <div class="col-md-4">
                <label class="form-label fw-bold small">Tìm kiếm</label>
                <select asp-for="RoleFilter" asp-items="Model.RoleList" class="form-select">
                    <option value="">-- Tất cả vai trò --</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-dark w-100">Áp dụng</button>
                <a asp-page="./Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-counterclockwise"></i></a>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive bg-white rounded shadow-sm border">
    <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Họ tên</th>
                <th>Email</th>
                <th>Vai trò</th>
                <th>Ngày tạo</th>
                <th>Trạng thái</th>
                <th class="text-end px-4">Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Users)
            {
                <tr>
                    <td class="text-muted small">#@item.UserId</td>
                    <td class="fw-bold text-dark">@item.FullName</td>
                    <td>@item.Email</td>
                    <td>
                        <span class="badge @(item.Role.RoleName == "Admin" ? "bg-danger" : "bg-info text-dark")">
                            @item.Role.RoleName
                        </span>
                    </td>
                    <td class="small">@(item.CreatedAt?.ToString("dd/MM/yyyy") ?? "N/A")</td>
                    <td>
                        @if (item.Status == "Active")
                        {
                            <span class="badge bg-success-subtle text-success border border-success-subtle px-2">Hoạt động</span>
                        }
                        else
                        {
                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2">@item.Status</span>
                        }
                    </td>
                    <td class="text-end px-4">
                        <div class="btn-group btn-group-sm">
                            <a asp-page="./Edit" asp-route-id="@item.UserId" class="btn btn-outline-secondary" title="Sửa"><i class="bi bi-pencil"></i></a>
                            <a asp-page="./Details" asp-route-id="@item.UserId" class="btn btn-outline-secondary" title="Chi tiết"><i class="bi bi-eye"></i></a>
                            <a asp-page="./Delete" asp-route-id="@item.UserId" class="btn btn-outline-danger" title="Xóa"><i class="bi bi-trash"></i></a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>