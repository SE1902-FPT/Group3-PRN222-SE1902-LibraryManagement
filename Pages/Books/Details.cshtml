@page
@model Group3_SE1902_PRN222_LibraryManagement.Pages.Books.DetailsModel
@{
    ViewData["Title"] = Model.Book?.Title ?? "Chi tiết sách";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'sunny-yellow': '#FFD93D',
                        'soft-orange': '#FF8400',
                        'fresh-green': '#6BCB77',
                        'soft-blue': '#4D96FF',
                    },
                    fontFamily: {
                        sans: ['Lexend', 'sans-serif'],
                    },
                    borderRadius: {
                        'xl-friendly': '24px',
                        '2xl-friendly': '32px',
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #FFFDF5;
        }
    </style>
</head>
<body class="antialiased text-gray-800">
    <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100 px-6 py-4">
        <div class="max-w-7xl mx-auto flex items-center justify-between gap-4">
            <div class="flex items-center gap-2 shrink-0">
                <div class="bg-sunny-yellow p-2 rounded-xl-friendly">
                    <svg class="h-8 w-8 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18 18.246 18.477 16.5 18c-1.746 0-3.332.477-4.5 1.253" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                </div>
                <span class="font-bold text-xl tracking-tight hidden md:block">Thư Viện Nhí</span>
            </div>
            <a href="/" class="flex items-center gap-2 text-gray-600 hover:text-soft-orange transition-colors">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
                <span class="font-medium">Quay lại</span>
            </a>
        </div>
    </nav>

    <main class="max-w-5xl mx-auto px-6 py-12">
        <div class="bg-white rounded-2xl-friendly shadow-xl overflow-hidden">
            <div class="md:flex">
                <div class="md:w-1/3 bg-gray-100 p-8 flex items-center justify-center">
                    <div class="w-full aspect-[2/3] bg-gray-200 rounded-xl overflow-hidden shadow-lg">
                        <img alt="@(Model.Book?.Title ?? "Book cover")" class="w-full h-full object-cover" src="https://images.unsplash.com/photo-1544648151-0738d38e67f7?auto=format&fit=crop&q=80&w=400" />
                    </div>
                </div>
                <div class="md:w-2/3 p-8">
                    <div class="flex items-start justify-between mb-4">
                        <h1 class="text-3xl font-bold text-gray-900">@Model.Book.Title</h1>
                        @if (Model.TeacherRecommendations.Any())
                        {
                            <span class="bg-fresh-green text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">Gợi ý</span>
                        }
                    </div>

                    <div class="space-y-4 mb-6">
                        <div class="flex items-center gap-2">
                            <span class="text-gray-500 font-medium">Tác giả:</span>
                            <span class="font-semibold">@Model.Book.Author</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="text-gray-500 font-medium">Nhà xuất bản:</span>
                            <span class="font-semibold">@Model.Book.Publisher</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="text-gray-500 font-medium">Năm xuất bản:</span>
                            <span class="font-semibold">@Model.Book.PublishYear</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="text-gray-500 font-medium">Thể loại:</span>
                            <span class="font-semibold">@Model.Book.Category?.CategoryName</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="text-gray-500 font-medium">Số bản có sẵn:</span>
                            <span class="font-semibold @(Model.AvailableCopies > 0 ? "text-fresh-green" : "text-red-500")">
                                @Model.AvailableCopies / @Model.Book.BookCopies.Count
                            </span>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Book.Description))
                    {
                        <div class="mb-6">
                            <h3 class="text-lg font-bold mb-2">Mô tả</h3>
                            <p class="text-gray-600 leading-relaxed">@Model.Book.Description</p>
                        </div>
                    }

                    @if (Model.TeacherRecommendations.Any())
                    {
                        <div class="mb-6">
                            <h3 class="text-lg font-bold mb-3">Gợi ý từ thầy cô</h3>
                            <div class="space-y-2">
                                @foreach (var rec in Model.TeacherRecommendations)
                                {
                                    <div class="bg-yellow-50 border border-yellow-100 rounded-xl p-3">
                                        <div class="flex items-center gap-2 mb-1">
                                            <div class="w-8 h-8 bg-soft-orange rounded-full flex items-center justify-center text-white text-sm font-bold">
                                                @(rec.Teacher?.FullName?.FirstOrDefault() ?? 'T')
                                            </div>
                                            <span class="font-semibold text-sm">@rec.Teacher?.FullName</span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(rec.Note))
                                        {
                                            <p class="text-gray-600 text-sm pl-10">@rec.Note</p>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div class="flex gap-4">
                        @if (Model.AvailableCopies > 0)
                        {
                            <button class="px-8 py-3 bg-fresh-green hover:bg-green-500 text-white font-bold rounded-xl-friendly transition-all shadow-lg">
                                Đăng ký mượn
                            </button>
                        }
                        else
                        {
                            <button class="px-8 py-3 bg-gray-300 text-gray-600 font-bold rounded-xl-friendly cursor-not-allowed" disabled>
                                Hết sách
                            </button>
                        }
                        <button class="px-8 py-3 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold rounded-xl-friendly transition-colors">
                            Yêu thích
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </main>
</body>
</html>
