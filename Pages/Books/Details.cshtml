@page
@model Group3_SE1902_PRN222_LibraryManagement.Pages.Books.DetailsModel
@{
    ViewData["Title"] = Model.Book?.Title ?? "Chi tiết sách";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'sunny-yellow': '#FFD93D',
                        'soft-orange': '#FF8400',
                        'fresh-green': '#6BCB77',
                        'soft-blue': '#4D96FF',
                    },
                    fontFamily: {
                        sans: ['Lexend', 'sans-serif'],
                    },
                    borderRadius: {
                        'xl-friendly': '24px',
                        '2xl-friendly': '32px',
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #FFFDF5;
        }
    </style>
</head>
<body class="antialiased text-gray-800">
    <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100 px-6 py-4">
        <div class="max-w-7xl mx-auto flex items-center justify-between gap-4">
            <!-- Logo → Homepage -->
            <a href="/" class="flex items-center gap-2 shrink-0">
                <div class="bg-sunny-yellow p-2 rounded-xl-friendly">
                    <svg class="h-8 w-8 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18 18.246 18.477 16.5 18c-1.746 0-3.332.477-4.5 1.253" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                </div>
                <span class="font-bold text-xl tracking-tight hidden md:block">Thư Viện Nhí</span>
            </a>

            <div class="flex items-center gap-4">
                <!-- Trang chủ (visible ngoài) -->
                <a href="/" class="flex items-center gap-1.5 text-gray-600 hover:text-soft-orange transition-colors font-medium">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                    </svg>
                    <span class="hidden sm:block">Trang chủ</span>
                </a>
                <!-- Nút Quay lại (visible ngoài) -->
                <a href="/Student/Book" class="flex items-center gap-1.5 text-gray-600 hover:text-soft-orange transition-colors font-medium">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                    <span class="hidden sm:block">Quay lại</span>
                </a>

                <!-- Profile Dropdown -->
                <div class="relative" id="profile-wrapper">
                    <button id="profile-btn" class="flex items-center gap-3 bg-gray-50 px-3 py-1.5 rounded-full border border-gray-100 hover:border-sunny-yellow transition-all">
                        <div class="text-right hidden sm:block">
                            <div class="text-sm font-bold leading-none">@Model.CurrentStudent?.FullName</div>
                            <div class="text-[10px] text-gray-500 font-medium tracking-wider uppercase">Lớp @Model.StudentClassName</div>
                        </div>
                        <div class="w-10 h-10 rounded-full bg-soft-orange border-2 border-white overflow-hidden shrink-0">
                            <img alt="Avatar" class="w-full h-full object-cover"
                                 src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.CurrentStudent?.FullName ?? "S")&background=FF8400&color=fff" />
                        </div>
                        <svg class="h-4 w-4 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                        </svg>
                    </button>
                    <div id="profile-dropdown" class="absolute right-0 mt-2 w-48 bg-white rounded-2xl shadow-xl border border-gray-100 hidden z-50 overflow-hidden">
                        <a href="/Student/Book" class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 transition-colors">
                            <svg class="h-5 w-5 text-soft-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18 18.246 18.477 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
                            </svg>
                            <span class="text-sm font-medium text-gray-700">Mượn sách</span>
                        </a>
                        <div class="border-t border-gray-100"></div>
                        <a href="/Student/FavoriteBooks" class="flex items-center gap-3 px-4 py-3 hover:bg-gray-50 transition-colors">
                            <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                            </svg>
                            <span class="text-sm font-medium text-gray-700">Sách yêu thích</span>
                        </a>
                        <div class="border-t border-gray-100"></div>
                        <a href="/Logout" class="flex items-center gap-3 px-4 py-3 hover:bg-red-50 transition-colors group">
                            <svg class="h-5 w-5 text-gray-400 group-hover:text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                            </svg>
                            <span class="text-sm font-medium text-gray-700 group-hover:text-red-500">Đăng xuất</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-5xl mx-auto px-6 py-12">
        <!-- Thông báo kết quả -->
        @if (TempData["Message"] != null)
        {
            var isSuccess = TempData["MessageType"]?.ToString() == "success";
            <div class="mb-6 flex items-start gap-3 px-5 py-4 rounded-2xl-friendly border
                        @(isSuccess ? "bg-green-50 border-green-200 text-green-800" : "bg-red-50 border-red-200 text-red-800")">
                <p class="font-medium">@TempData["Message"]</p>
            </div>
        }

        <div class="bg-white rounded-2xl-friendly shadow-xl overflow-hidden">
            <div class="md:flex">
                <div class="md:w-1/3 bg-gray-100 p-8 flex items-center justify-center">
                    <div class="w-full aspect-[2/3] bg-gray-200 rounded-xl overflow-hidden shadow-lg">
                        <img alt="@(Model.Book?.Title ?? "Book cover")" class="w-full h-full object-cover" src="https://images.unsplash.com/photo-1544648151-0738d38e67f7?auto=format&fit=crop&q=80&w=400" />
                    </div>
                </div>
                <div class="md:w-2/3 p-8">
                    <div class="flex items-start justify-between mb-4">
                        <h1 class="text-3xl font-bold text-gray-900">@(Model.Book?.Title ?? "Chi tiết sách")</h1>
                        @if (Model.TeacherRecommendations.Any())
                        {
                            <span class="bg-fresh-green text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">Gợi ý</span>
                        }
                    </div>

                    <div class="space-y-4 mb-6">
                        <div class="flex items-center gap-2">
                            <span class="text-gray-500 font-medium">Tác giả:</span>
                            <span class="font-semibold">@(Model.Book?.Author ?? "Chưa cập nhật")</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="text-gray-500 font-medium">Nhà xuất bản:</span>
                            <span class="font-semibold">@(Model.Book?.Publisher ?? "Chưa cập nhật")</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="text-gray-500 font-medium">Năm xuất bản:</span>
                            <span class="font-semibold">@(Model.Book?.PublishYear?.ToString() ?? "N/A")</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="text-gray-500 font-medium">Thể loại:</span>
                            <span class="font-semibold">@(Model.Book?.Category?.CategoryName ?? "Chưa phân loại")</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="text-gray-500 font-medium">Số bản có sẵn:</span>
                            <span class="font-semibold @(Model.AvailableCopies > 0 ? "text-fresh-green" : "text-red-500")">
                                @Model.AvailableCopies / @(Model.Book?.BookCopies.Count ?? 0)
                            </span>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Book?.Description))
                    {
                        <div class="mb-6">
                            <h3 class="text-lg font-bold mb-2">Mô tả</h3>
                            <p class="text-gray-600 leading-relaxed">@Model.Book.Description</p>
                        </div>
                    }

                    @if (Model.TeacherRecommendations.Any())
                    {
                        <div class="mb-6">
                            <h3 class="text-lg font-bold mb-3">Gợi ý từ thầy cô</h3>
                            <div class="space-y-2">
                                @foreach (var rec in Model.TeacherRecommendations)
                                {
                                    <div class="bg-yellow-50 border border-yellow-100 rounded-xl p-3">
                                        <div class="flex items-center gap-2 mb-1">
                                            <div class="w-8 h-8 bg-soft-orange rounded-full flex items-center justify-center text-white text-sm font-bold">
                                                @(rec.Teacher?.FullName?.FirstOrDefault() ?? 'T')
                                            </div>
                                            <span class="font-semibold text-sm">@rec.Teacher?.FullName</span>
                                        </div>
                                        @if (!string.IsNullOrEmpty(rec.Note))
                                        {
                                            <p class="text-gray-600 text-sm pl-10">@rec.Note</p>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    @{
                        var firstAvailableCopy = Model.Book.BookCopies.FirstOrDefault(c => c.Status == "Available");
                        var bookId = Model.Book.BookId;
                    }
                    <div class="flex gap-4">
                        @if (Model.BookRequestStatuses.ContainsKey(bookId))
                        {
                            var status = Model.BookRequestStatuses[bookId];
                            if (status == "Approved" || status == "Borrowed")
                            {
                                <button disabled class="flex-1 py-2.5 bg-gray-200 text-gray-500 font-bold rounded-xl-friendly text-sm cursor-not-allowed border border-gray-300">
                                    Đã được mượn
                                </button>
                            }
                            else
                            {
                                <button disabled class="flex-1 py-2.5 bg-gray-200 text-gray-500 font-bold rounded-xl-friendly text-sm cursor-not-allowed border border-gray-300">
                                    Đã đăng ký
                                </button>
                            }
                        }
                        else if (firstAvailableCopy != null && Model.PendingCount < 5)
                        {
                            <button type="button" onclick="openBorrowModal(@firstAvailableCopy.CopyId, '@Html.Raw(Model.Book.Title.Replace("'", "\\'"))')"
                                    class="w-full py-2.5 bg-fresh-green hover:bg-green-500 text-white font-bold rounded-xl-friendly text-sm transition-colors flex-1">
                                Mượn sách
                            </button>
                        }
                        else if (Model.PendingCount >= 5)
                        {
                            <button disabled class="flex-1 py-2.5 bg-gray-200 text-gray-400 font-bold rounded-xl-friendly text-sm cursor-not-allowed">
                                Đã đủ 5 yêu cầu
                            </button>
                        }
                        else if (Model.IsTeacherView)
                        {
                            <button disabled class="flex-1 py-2.5 bg-gray-200 text-gray-400 font-bold rounded-xl-friendly text-sm cursor-not-allowed">
                                Hết sách
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Borrow Request Modal -->
    @if (Model.IsStudentView)
    {
    <div id="borrowModal" class="fixed inset-0 z-[100] hidden items-center justify-center">
        <!-- Backdrop -->
        <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" onclick="closeBorrowModal()"></div>
        
        <!-- Modal Content -->
        <div class="relative bg-white rounded-2xl-friendly shadow-xl w-full max-w-md mx-4 overflow-hidden animate-in fade-in zoom-in duration-200">
            <div class="p-6">
                <!-- Header -->
                <div class="flex items-center justify-between mb-5">
                    <h3 class="text-xl font-bold text-gray-900">Đăng ký mượn sách</h3>
                    <button onclick="closeBorrowModal()" class="text-gray-400 hover:text-red-500 transition-colors">
                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                    </button>
                </div>

                <form method="post" asp-page-handler="Borrow">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="copyId" id="modalCopyId" />
                    <input type="hidden" name="bookId" value="@Model.Book?.BookId" />
                    
                    <div class="space-y-4">
                        <!-- Book Info -->
                        <div class="bg-sunny-yellow/10 p-4 rounded-xl-friendly">
                            <p class="text-sm font-bold text-gray-700 mb-1">Quyển sách:</p>
                            <p id="modalBookTitle" class="text-base font-bold text-soft-orange leading-snug"></p>
                        </div>

                        <!-- Student Info -->
                        <div class="bg-gray-50 border border-gray-100 p-4 rounded-xl-friendly space-y-2">
                            <div class="flex justify-between items-center">
                                <span class="text-sm text-gray-500">Người mượn:</span>
                                <span class="text-sm font-bold text-gray-800">@Model.CurrentStudent?.FullName</span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span class="text-sm text-gray-500">Lớp:</span>
                                <span class="text-sm font-bold text-gray-800">@Model.StudentClassName</span>
                            </div>
                        </div>

                        <!-- Date Selection -->
                        <div>
                            <label class="block text-sm font-bold text-gray-700 mb-2">Ngày dự kiến trả (Tối đa 1 tuần)</label>
                            <div class="relative">
                                <input type="date" name="expectedReturnDate" id="modalReturnDate" required
                                       style="color:transparent;"
                                       class="w-full px-4 py-2.5 rounded-xl-friendly border border-gray-200 bg-white focus:outline-none focus:ring-2 focus:ring-sunny-yellow"
                                       onchange="onDateChange(this.value)" />
                                <span id="modalDateDisplay" class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-800 text-sm pointer-events-none"></span>
                            </div>
                        </div>
                    </div>

                    <div class="mt-8 flex gap-3">
                        <button type="button" onclick="closeBorrowModal()" class="flex-1 py-2.5 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold rounded-xl-friendly transition-colors">
                            Hủy
                        </button>
                        <button type="submit" class="flex-1 py-2.5 bg-fresh-green hover:bg-green-500 text-white font-bold rounded-xl-friendly transition-colors">
                            Xác nhận mượn
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    }

    <script>
        function formatDDMMYYYY(isoVal) {
            if (!isoVal) return '';
            const [y, m, d] = isoVal.split('-');
            return `${d}/${m}/${y}`;
        }
        function onDateChange(isoVal) {
            document.getElementById('modalDateDisplay').textContent = formatDDMMYYYY(isoVal);
        }
        function openBorrowModal(copyId, title) {
            document.getElementById('modalCopyId').value = copyId;
            document.getElementById('modalBookTitle').innerText = title;

            const today = new Date();
            const toISO = (d) => d.toISOString().split('T')[0];
            const minDate = toISO(today);
            const max = new Date();
            max.setDate(today.getDate() + 7);
            const maxDate = toISO(max);

            const dateInput = document.getElementById('modalReturnDate');
            dateInput.min = minDate;
            dateInput.max = maxDate;
            dateInput.value = maxDate;
            document.getElementById('modalDateDisplay').textContent = formatDDMMYYYY(maxDate);

            const modal = document.getElementById('borrowModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeBorrowModal() {
            const modal = document.getElementById('borrowModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        // Profile dropdown
        document.addEventListener('DOMContentLoaded', function () {
            const profileBtn = document.getElementById('profile-btn');
            const profileDropdown = document.getElementById('profile-dropdown');
            profileBtn.addEventListener('click', function (e) {
                e.stopPropagation();
                profileDropdown.classList.toggle('hidden');
            });
            document.addEventListener('click', function (e) {
                if (!profileBtn.contains(e.target) && !profileDropdown.contains(e.target)) {
                    profileDropdown.classList.add('hidden');
                }
            });
        });
    </script>
</body>
</html>
