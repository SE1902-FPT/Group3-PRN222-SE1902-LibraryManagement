@page
@model ErrorModel
@{
    ViewData["Title"] = "Loi";
}

<div class="container py-5">
    <div class="card border-0 shadow-sm mx-auto" style="max-width: 680px;">
        <div class="card-body p-4 p-md-5">
            <h1 class="text-danger h3 mb-2">@Model.ErrorTitle</h1>
            <p class="text-muted mb-4">@Model.ErrorMessage</p>

            <div class="d-flex gap-2 flex-wrap">
                <a class="btn btn-primary" href="/Login">Dang nhap</a>
                <a class="btn btn-outline-secondary" href="/">Ve trang chu</a>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
            {
                <p class="mt-3 mb-0 small text-muted">Trang ban vua truy cap: <code>@Model.ReturnUrl</code></p>
            }
            @if (Model.ShowRequestId)
            {
                <p class="mt-2 mb-0 small text-muted">Request ID: <code>@Model.RequestId</code></p>
            }
        </div>
    </div>
</div>
