@page
@model IndexModel
@{
    ViewData["Title"] = "Thư Viện Trường Học Vui Vẻ";
    Layout = null;

    var defaultRecommendationCover = "https://images.unsplash.com/photo-1544648151-0738d38e67f7?auto=format&fit=crop&q=80&w=400";
    var defaultFeaturedCover = "https://images.unsplash.com/photo-1543004629-142a2ccc5ef6?auto=format&fit=crop&q=80&w=400";

    Func<string?, string, string> resolveBookImage = (rawUrl, fallbackUrl) =>
    {
        if (string.IsNullOrWhiteSpace(rawUrl))
        {
            return fallbackUrl;
        }

        var trimmed = rawUrl.Trim();

        if (trimmed.Contains(":\\", StringComparison.Ordinal))
        {
            return fallbackUrl;
        }

        if (trimmed.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            trimmed.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
        {
            return trimmed;
        }

        return trimmed.StartsWith("/") ? trimmed : "/" + trimmed;
    };
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Thư Viện Trường Học Vui Vẻ</title>
    <!-- Tailwind CSS v3 with Plugins -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <!-- Google Fonts: Lexend for a friendly, readable feel -->
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'sunny-yellow': '#FFD93D',
                        'soft-orange': '#FF8400',
                        'fresh-green': '#6BCB77',
                        'soft-blue': '#4D96FF',
                    },
                    fontFamily: {
                        sans: ['Lexend', 'sans-serif'],
                    },
                    borderRadius: {
                        'xl-friendly': '24px',
                        '2xl-friendly': '32px',
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #FFFDF5;
        }
        .book-card-shadow {
            box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.1);
        }
        .hover-pop {
            transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .hover-pop:hover {
            transform: scale(1.05);
        }
    </style>
</head>
<body class="antialiased text-gray-800">

    <!-- BEGIN: Navigation -->
    <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100 px-6 py-4" data-purpose="main-navigation">
        <div class="max-w-7xl mx-auto flex items-center justify-between gap-4">
            <!-- Logo -->
            <div class="flex items-center gap-2 shrink-0">
                <div class="bg-sunny-yellow p-2 rounded-xl-friendly">
                    <svg class="h-8 w-8 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18 18.246 18.477 16.5 18c-1.746 0-3.332.477-4.5 1.253" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                </div>
                <span class="font-bold text-xl tracking-tight hidden md:block">Thư Viện Nhí</span>
            </div>

            <!-- Search Bar -->
            <div class="flex-grow max-w-xl relative" data-purpose="search-container">
                <input class="w-full pl-12 pr-4 py-3 rounded-full border-2 border-gray-100 focus:border-sunny-yellow focus:ring-0 text-sm md:text-base" placeholder="Tìm kiếm sách, tác giả..." type="text" />
                <div class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                    </svg>
                </div>
            </div>

            <!-- User Actions -->
            <div class="flex items-center gap-4 shrink-0">
                @if (Model.IsAuthenticated)
                {
                    <!-- Notification Bell -->
                    <div class="relative" id="notification-wrapper">
                        <button id="notification-btn" class="relative p-2 text-gray-500 hover:bg-gray-50 rounded-full transition-colors" data-purpose="notifications">
                            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                            </svg>
                            @if (Model.Notifications.Any(n => n.IsRead == false))
                            {
                                <span class="absolute top-2 right-2 w-2 h-2 bg-red-500 rounded-full border-2 border-white"></span>
                            }
                        </button>
                        <!-- Notification Dropdown -->
                        <div id="notification-dropdown" class="absolute right-0 mt-2 w-80 bg-white rounded-2xl shadow-xl border border-gray-100 hidden z-50">
                            <div class="p-4 border-b border-gray-100 flex justify-between items-center">
                                <span class="font-bold">Thông báo mới</span>
                                <span class="text-xs text-soft-orange cursor-pointer">Đánh dấu đã đọc</span>
                            </div>
                            <div class="max-h-64 overflow-y-auto">
                                @if (Model.Notifications.Any())
                                {
                                    foreach (var notif in Model.Notifications)
                                    {
                                        <div class="p-3 border-b border-gray-50 hover:bg-gray-50 transition-colors">
                                            <p class="text-sm font-medium">@notif.Message</p>
                                            <p class="text-xs text-gray-400 mt-1">@notif.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</p>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="p-4 text-center text-sm text-gray-400">
                                        Không có thông báo mới.
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- User Profile with Logout -->
                    <div class="flex items-center gap-3 bg-gray-50 px-3 py-1.5 rounded-full border border-gray-100" data-purpose="student-profile">
                        <div class="text-right hidden sm:block">
                            <div class="text-sm font-bold leading-none">@Model.LoggedInUserName</div>
                            <div class="text-[10px] text-gray-500 font-medium tracking-wider uppercase">@Model.LoggedInUserRole</div>
                        </div>
                        <div class="w-10 h-10 rounded-full bg-soft-orange border-2 border-white overflow-hidden">
                            <img alt="Avatar" class="w-full h-full object-cover" src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.LoggedInUserName ?? "U")&background=FF8400&color=fff" />
                        </div>
                        <a href="/Logout" class="ml-1 px-4 py-2 bg-red-500 hover:bg-red-600 text-white text-sm font-bold rounded-full transition-colors" title="Đăng xuất">
                            Đăng xuất
                        </a>
                    </div>
                }
                else
                {
                    <!-- Login Button for Guests -->
                    <a href="/Login" class="flex items-center gap-2 px-6 py-2.5 bg-soft-orange hover:bg-orange-500 text-white font-bold rounded-full transition-all hover:scale-105 shadow-md">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                        </svg>
                        Đăng nhập
                    </a>
                }
            </div>
        </div>
    </nav>
    <!-- END: Navigation -->

    <main class="max-w-7xl mx-auto px-6 py-8 space-y-12">

        <!-- BEGIN: Hero Banner -->
        <section class="relative bg-sunny-yellow rounded-2xl-friendly overflow-hidden p-8 md:p-12 lg:p-16 flex flex-col md:flex-row items-center gap-8" data-purpose="hero-banner">
            <!-- Decorative background -->
            <div class="absolute top-0 right-0 -mr-20 -mt-20 w-64 h-64 bg-yellow-300 rounded-full opacity-50 blur-3xl"></div>
            <div class="relative z-10 w-full md:w-1/2 space-y-6 text-center md:text-left">
                <h1 class="text-3xl md:text-5xl font-extrabold text-gray-900 leading-tight">
                    @if (Model.IsAuthenticated)
                    {
                        <span>Chào bạn, <span class="text-soft-orange">@Model.LoggedInUserName</span></span>
                    }
                    else
                    {
                        <span>Chào mừng đến <span class="text-soft-orange">Thư Viện Nhí!</span></span>
                    }
                </h1>
                <p class="text-lg md:text-xl text-gray-800 opacity-90">
                    Hôm nay bạn muốn phiêu lưu vào cuốn sách nào? Có rất nhiều thế giới mới đang chờ bạn đấy!
                </p>
                <div class="flex flex-wrap gap-4 justify-center md:justify-start pt-2">
                    <button class="px-8 py-4 bg-gray-900 text-white font-bold rounded-xl-friendly hover:bg-gray-800 transition-all hover:scale-105 shadow-lg">
                        Khám phá ngay
                    </button>
                    @if (Model.IsAuthenticated)
                    {
                        <button class="px-8 py-4 bg-white text-gray-900 font-bold rounded-xl-friendly border-2 border-transparent hover:border-white hover:bg-transparent transition-all hover:scale-105">
                            Tủ sách của tôi
                        </button>
                    }
                    else
                    {
                        <a href="/Login" class="px-8 py-4 bg-white text-gray-900 font-bold rounded-xl-friendly border-2 border-transparent hover:border-white hover:bg-transparent transition-all hover:scale-105 inline-block">
                            Đăng nhập ngay
                        </a>
                    }
                </div>
            </div>
            <div class="relative z-10 w-full md:w-1/2 flex justify-center">
                <div class="relative w-full max-w-sm">
                    <img alt="Library Illustration" class="w-full h-auto drop-shadow-2xl rounded-2xl-friendly" src="/Asset/anh-mo-ta-03d8a2f51bb4436cbba65ba328ba27e2.jpg" />
                    <div class="absolute -top-4 -right-4 bg-white p-3 rounded-2xl shadow-xl animate-bounce">✨</div>
                    <div class="absolute -bottom-4 -left-4 bg-white p-3 rounded-2xl shadow-xl">📚</div>
                </div>
            </div>
        </section>
        <!-- END: Hero Banner -->

        <!-- BEGIN: Categories -->
        <section data-purpose="category-list">
            <h2 class="text-2xl font-bold mb-8">Khám phá theo chủ đề</h2>
            <div class="grid gap-6" style="grid-template-columns: repeat(auto-fill, minmax(130px,1fr))">
                @{
                    var categoryEmojis = new[] { "📖", "🔬", "🏰", "🌍", "🎨", "🎵", "🧮", "🦁" };
                    var categoryBgColors = new[] { "#4D96FF", "#6BCB77", "#FFD93D", "#FF8400", "#4D96FF", "#6BCB77", "#FFD93D", "#FF8400" };
                    int catIdx = 0;
                }
                @foreach (var cat in Model.Categories)
                {
                    var emoji = categoryEmojis[catIdx % categoryEmojis.Length];
                    var bgColor = categoryBgColors[catIdx % categoryBgColors.Length];
                    catIdx++;
                    <div class="flex flex-col items-center gap-4 group cursor-pointer">
                        <div class="w-24 h-24 sm:w-28 sm:h-28 rounded-full flex items-center justify-center text-4xl group-hover:scale-110 transition-transform duration-300 shadow-md" style="background-color: @bgColor">
                            @emoji
                        </div>
                        <span class="font-bold text-gray-700 text-center text-sm">@cat.CategoryName</span>
                    </div>
                }
            </div>
        </section>
        <!-- END: Categories -->

        <!-- BEGIN: Teacher Recommendations -->
        <section data-purpose="teacher-recommendations">
            <div class="flex items-center justify-between mb-8">
                <h2 class="text-2xl font-bold">Gợi ý từ Thầy Cô @(Model.IsAuthenticated ? "lớp " + Model.UserClassName : "")</h2>
                <a class="text-soft-orange font-bold hover:underline" href="/TeacherRecommendations">Xem tất cả →</a>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
                @foreach (var rec in Model.Recommendations)
                {
                    var available = rec.Book?.BookCopies?.Count(c => c.Status == "Available") ?? 0;
                    var recommendationImage = resolveBookImage(rec.Book?.ImageUrl, defaultRecommendationCover);
                    <div class="bg-white p-4 rounded-xl-friendly book-card-shadow flex flex-col hover-pop">
                        <div class="relative aspect-[3/4] mb-4 overflow-hidden rounded-xl">
                            <span class="absolute top-2 left-2 z-10 bg-fresh-green text-white text-[10px] font-bold px-2 py-1 rounded-full uppercase tracking-wider">Đề xuất</span>
                            <img alt="Book cover" class="w-full h-full object-cover" src="@recommendationImage" />
                        </div>
                        <h3 class="font-bold text-lg leading-tight mb-1">@rec.Book?.Title</h3>
                        <p class="text-gray-500 text-sm mb-1">@rec.Book?.Author</p>
                        <p class="text-xs mb-2 @(available > 0 ? "text-fresh-green" : "text-red-500") font-bold">Có sẵn: @available / @rec.Book?.BookCopies?.Count</p>
                        <p class="text-gray-400 text-xs mb-4 italic">GV: @rec.Teacher?.FullName đề xuất</p>
                        <a href="/Books/Details?id=@rec.BookId" class="mt-auto w-full py-2 text-center bg-gray-100 hover:bg-sunny-yellow text-gray-700 font-bold rounded-xl transition-colors block">Xem chi tiết</a>
                    </div>
                }
                @if (!Model.Recommendations.Any())
                {
                    <div class="col-span-4 text-center py-12 text-gray-400">
                        <div class="text-5xl mb-4">📚</div>
                        <p>Chưa có gợi ý nào từ thầy cô.</p>
                    </div>
                }
            </div>
        </section>
        <!-- END: Teacher Recommendations -->

        <!-- BEGIN: Browse All Books -->
        <section data-purpose="browse-all-books">
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h2 class="text-2xl font-bold">Thư viện sách 📖</h2>
                    <p class="text-gray-500 mt-1">Xem toàn bộ sách và đăng ký mượn ngay</p>
                </div>
                <a href="/Student/Book" class="flex items-center gap-2 px-6 py-3 bg-sunny-yellow hover:bg-yellow-400 text-gray-800 font-bold rounded-xl-friendly transition-all hover:scale-105 shadow-md">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18 18.246 18.477 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
                    Xem tất cả sách
                </a>
            </div>
            <div class="bg-sunny-yellow/10 border-2 border-dashed border-sunny-yellow rounded-2xl-friendly p-10 text-center">
                <div class="text-6xl mb-4">📚</div>
                <h3 class="text-xl font-bold text-gray-800 mb-2">Khám phá kho sách của thư viện</h3>
                <p class="text-gray-500 mb-6">Hàng trăm đầu sách thuộc nhiều thể loại đang chờ bạn — từ khoa học, văn học đến nghệ thuật!</p>
                <a href="/Student/Book" class="inline-flex items-center gap-2 px-8 py-4 bg-gray-900 hover:bg-gray-700 text-white font-bold rounded-xl-friendly transition-all hover:scale-105 shadow-lg">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                    Vào trang mượn sách
                </a>
            </div>
        </section>
        <!-- END: Browse All Books -->

        <!-- BEGIN: New Books Grid -->
        <section data-purpose="new-arrivals">
            <div class="flex items-center gap-3 mb-8">
                <h2 class="text-2xl font-bold">Sách mới về thư viện</h2>
                <span class="bg-red-100 text-red-600 px-3 py-1 rounded-full text-xs font-bold animate-pulse">NEW</span>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
                @foreach (var book in Model.FeaturedBooks)
                {
                    var featuredImage = resolveBookImage(book.ImageUrl, defaultFeaturedCover);
                    <div class="group cursor-pointer">
                        <div class="relative aspect-[2/3] bg-gray-200 rounded-xl overflow-hidden mb-3">
                            <img alt="@book.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform" src="@featuredImage" />
                        </div>
                        <h4 class="font-bold text-sm truncate">@book.Title</h4>
                        <p class="text-xs text-gray-500">@book.Author</p>
                        <a href="/Books/Details?id=@book.BookId" class="block mt-2 w-full text-center py-1.5 bg-gray-100 hover:bg-sunny-yellow text-gray-700 text-xs font-bold rounded-lg transition-colors">Xem chi tiết</a>
                    </div>
                }
            </div>
        </section>
        <!-- END: New Books Grid -->

    </main>

    <!-- BEGIN: Footer Dashboard -->
    <footer class="max-w-7xl mx-auto px-6 pb-12 mt-4" data-purpose="footer-stats">
        <div class="bg-white border-4 border-fresh-green rounded-2xl-friendly p-6 md:p-8 flex flex-col md:flex-row items-center justify-between gap-8 shadow-xl">
            <div class="flex items-center gap-6">
                <div class="w-16 h-16 bg-fresh-green/20 rounded-2xl flex items-center justify-center text-3xl">🏅</div>
                <div>
                    <h3 class="font-bold text-xl">Thành tích của @(Model.IsAuthenticated ? (Model.LoggedInUserName?.Split(' ').LastOrDefault() ?? "bạn") : "bạn")</h3>
                    <p class="text-gray-500">Cố gắng lên nhé, bạn đang làm rất tốt!</p>
                </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 w-full md:w-auto">
                <div class="bg-gray-50 px-6 py-4 rounded-xl-friendly text-center border border-gray-100">
                    <div class="text-2xl font-black text-soft-blue">@Model.CurrentUser?.BorrowRecordStudents.Count</div>
                    <div class="text-xs font-bold text-gray-400 uppercase tracking-widest">Đã mượn</div>
                </div>
                <div class="bg-gray-50 px-6 py-4 rounded-xl-friendly text-center border border-gray-100">
                    <div class="text-2xl font-black text-soft-orange">@Model.Recommendations.Count</div>
                    <div class="text-xs font-bold text-gray-400 uppercase tracking-widest">Đề xuất mới</div>
                </div>
                <div class="bg-gray-50 px-6 py-4 rounded-xl-friendly text-center border border-gray-100">
                    <div class="text-2xl font-black text-fresh-green">@Model.Categories.Count</div>
                    <div class="text-xs font-bold text-gray-400 uppercase tracking-widest">Chủ đề</div>
                </div>
            </div>
            <div class="shrink-0">
                <button class="bg-fresh-green hover:bg-green-500 text-white px-8 py-3 rounded-xl-friendly font-bold shadow-lg transition-all">
                    Xem bảng xếp hạng
                </button>
            </div>
        </div>
        <div class="mt-8 text-center text-gray-400 text-sm">
            <p>&copy; @DateTime.Now.Year Thư viện Trường. Chúc các em đọc sách vui vẻ!</p>
        </div>
    </footer>
    <!-- END: Footer Dashboard -->

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Notification bell
            const bell = document.getElementById('notification-btn');
            const notifDropdown = document.getElementById('notification-dropdown');

            bell.addEventListener('click', function (e) {
                e.stopPropagation();
                notifDropdown.classList.toggle('hidden');
                profileDropdown.classList.add('hidden');
            });

            // Profile dropdown
            const profileBtn = document.getElementById('profile-btn');
            const profileDropdown = document.getElementById('profile-dropdown');

            profileBtn.addEventListener('click', function (e) {
                e.stopPropagation();
                profileDropdown.classList.toggle('hidden');
                notifDropdown.classList.add('hidden');
            });

            // Close both on outside click
            document.addEventListener('click', function (e) {
                if (!bell.contains(e.target) && !notifDropdown.contains(e.target)) {
                    notifDropdown.classList.add('hidden');
                }
                if (!profileBtn.contains(e.target) && !profileDropdown.contains(e.target)) {
                    profileDropdown.classList.add('hidden');
                }
            });
        });
    </script>
</body>
</html>
