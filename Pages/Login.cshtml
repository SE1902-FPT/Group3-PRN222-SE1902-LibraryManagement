@page
@model Group3_SE1902_PRN222_LibraryManagement.Pages.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'sunny-yellow': '#FFD93D',
                        'soft-orange': '#FF8400',
                        'fresh-green': '#6BCB77',
                        'soft-blue': '#4D96FF',
                    },
                    fontFamily: {
                        sans: ['Lexend', 'sans-serif'],
                    },
                    borderRadius: {
                        'xl-friendly': '24px',
                        '2xl-friendly': '32px',
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #FFFDF5;
            font-family: 'Lexend', sans-serif;
        }
    </style>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
</head>
<body class="min-h-screen flex items-center justify-center p-4">

    <div class="w-full max-w-md">
        <!-- Logo & Title -->
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-20 h-20 bg-sunny-yellow rounded-2xl-friendly shadow-lg mb-4">
                <svg class="h-10 w-10 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18 18.246 18.477 16.5 18c-1.746 0-3.332.477-4.5 1.253" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
            </div>
            <h1 class="text-2xl font-bold text-gray-800">Thư Viện Nhí</h1>
            <p class="text-gray-500 mt-1">Chào mừng bạn quay lại! 📚</p>
        </div>

        <!-- Login Card -->
        <div class="bg-white rounded-3xl shadow-xl border-4 border-sunny-yellow p-8">
            <h2 class="text-xl font-bold text-center mb-6 text-gray-800">Đăng nhập ngay nào</h2>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="mb-6 p-4 bg-red-100 border-2 border-red-400 text-red-700 rounded-xl-friendly text-sm font-medium">
                    ⚠️ @Model.ErrorMessage
                </div>
            }

            <form method="post" class="space-y-5">
                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">📧 Email của bạn</label>
                    <input type="email" 
                           asp-for="Email" 
                           class="w-full px-5 py-4 border-2 border-gray-200 rounded-xl-friendly focus:border-sunny-yellow focus:ring-0 text-gray-700 transition-colors"
                           placeholder="nhap email o day..." 
                           required />
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-700 mb-2">🔑 Mật khẩu</label>
                    <input type="password" 
                           asp-for="Password" 
                           class="w-full px-5 py-4 border-2 border-gray-200 rounded-xl-friendly focus:border-sunny-yellow focus:ring-0 text-gray-700 transition-colors"
                           placeholder="nhap mat khau..." 
                           required />
                </div>

                <button type="submit" 
                        class="w-full py-4 bg-soft-blue hover:bg-blue-600 text-white font-bold rounded-xl-friendly shadow-lg transition-all hover:scale-[1.02]">
                    🚀 Vào thư viện
                </button>
            </form>

            <div class="mt-6 text-center">
                <p class="text-sm text-gray-400">
                    <a href="/" class="text-soft-orange font-bold hover:underline">← Quay về trang chủ</a>
                </p>
            </div>
        </div>

        <!-- Decorative Elements -->
        <div class="flex justify-between mt-8 px-4">
            <span class="text-4xl animate-bounce">📖</span>
            <span class="text-4xl animate-bounce" style="animation-delay: 0.2s;">✏️</span>
            <span class="text-4xl animate-bounce" style="animation-delay: 0.4s;">🎨</span>
            <span class="text-4xl animate-bounce" style="animation-delay: 0.6s;">⭐</span>
        </div>
    </div>

</body>
</html>