@page
@model Group3_SE1902_PRN222_LibraryManagement.Pages.Parent.BorrowedBooksModel

@{
    ViewData["Title"] = "Sách đang mượn";
    Layout = "_ParentLayout";
}

<section class="relative bg-soft-blue rounded-2xl-friendly overflow-hidden p-8 md:p-12 flex flex-col lg:flex-row items-center gap-8 text-white">
    <div class="absolute -top-16 -right-10 h-56 w-56 rounded-full bg-white/15 blur-3xl"></div>
    <div class="relative z-10 w-full lg:w-2/3 space-y-5 text-center lg:text-left">
        <span class="inline-flex items-center gap-2 rounded-full bg-white/15 px-4 py-2 text-xs font-bold uppercase tracking-[0.3em] text-white">Theo dõi hiện tại</span>
        <h1 class="text-3xl md:text-5xl font-extrabold leading-tight">Sách con đang mượn</h1>
        <p class="text-lg text-white/85">Chỉ hiển thị các sách có <code class="rounded bg-white/10 px-2 py-1 text-sm text-white">ReturnDate IS NULL</code>.</p>
    </div>
    <div class="relative z-10 w-full lg:w-1/3">
        <div class="rounded-2xl-friendly bg-white/15 p-6 backdrop-blur-sm">
            <div class="text-xs font-bold uppercase tracking-[0.25em] text-white/70">Số học sinh</div>
            <div class="mt-3 text-4xl font-extrabold">@Model.StudentOptions.Count</div>
        </div>
    </div>
</section>

@if (Model.StudentOptions.Count == 0)
{
    <section class="bg-white rounded-2xl-friendly p-8 shadow-xl text-center">
        <div class="text-5xl mb-4">📘</div>
        <h2 class="text-2xl font-bold text-gray-900 mb-3">Chưa có dữ liệu học sinh</h2>
        <p class="text-gray-500 max-w-2xl mx-auto">Tài khoản phụ huynh này chưa được gắn với học sinh nào.</p>
    </section>
}
else
{
    <section class="bg-white rounded-2xl-friendly p-6 md:p-8 shadow-xl">
        <form method="get" class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_320px]">
            <div>
                <label class="mb-3 block text-sm font-bold text-gray-700" for="studentId">Chọn học sinh</label>
                <select class="w-full rounded-full border-2 border-gray-100 bg-white px-5 py-4 text-base font-medium text-gray-800 focus:border-sunny-yellow focus:ring-0" id="studentId" name="studentId" onchange="this.form.submit()">
                    @if (Model.RequiresStudentSelection)
                    {
                        <option value="">Chọn học sinh để xem danh sách</option>
                    }
                    @foreach (var student in Model.StudentOptions)
                    {
                        var selected = Model.SelectedStudent?.StudentId == student.StudentId;
                        <option value="@student.StudentId" selected="@selected">
                            @student.StudentName@(string.IsNullOrWhiteSpace(student.Relationship) ? string.Empty : $" - {student.Relationship}")
                        </option>
                    }
                </select>
            </div>
            <div class="rounded-2xl-friendly bg-gray-50 p-5 border border-gray-100 text-gray-500">
                Dữ liệu chỉ được tải sau khi học sinh thuộc quyền phụ huynh được chọn hợp lệ.
            </div>
        </form>
    </section>

    @if (Model.RequiresStudentSelection && Model.SelectedStudent == null)
    {
        <section class="bg-white rounded-2xl-friendly p-8 shadow-xl text-center">
            <div class="text-5xl mb-4">🔎</div>
            <h2 class="text-2xl font-bold text-gray-900 mb-3">Hãy chọn học sinh</h2>
            <p class="text-gray-500 max-w-2xl mx-auto">Sau khi chọn, hệ thống sẽ hiển thị toàn bộ sách mà con đang mượn.</p>
        </section>
    }
    else if (Model.SelectedStudent != null)
    {
        <section class="bg-white rounded-2xl-friendly p-6 md:p-8 shadow-xl">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3 mb-6">
                <div>
                    <h2 class="text-3xl font-bold text-gray-900 mb-2">@Model.SelectedStudent.StudentName</h2>
                    <p class="text-gray-500">Danh sách sách đang được giữ bởi học sinh này.</p>
                </div>
                <a class="text-soft-orange font-bold hover:underline" asp-page="/Parent/History" asp-route-studentId="@Model.SelectedStudent.StudentId">Xem lịch sử mượn →</a>
            </div>

            @if (Model.BorrowedBooks.Count == 0)
            {
                <div class="rounded-2xl-friendly bg-gray-50 px-6 py-10 text-center text-gray-500">
                    Học sinh này hiện không có sách nào đang mượn.
                </div>
            }
            else
            {
                <div class="overflow-x-auto rounded-2xl border border-gray-100">
                    <table class="min-w-full divide-y divide-gray-100">
                        <thead class="bg-gray-50">
                            <tr class="text-left text-sm font-bold text-gray-600">
                                <th class="px-5 py-4">Tên sách</th>
                                <th class="px-5 py-4">Ngày mượn</th>
                                <th class="px-5 py-4">Hạn trả</th>
                                <th class="px-5 py-4">Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100 bg-white text-sm text-gray-700">
                            @foreach (var item in Model.BorrowedBooks)
                            {
                                var badgeClass = item.BorrowStatus == "Quá hạn"
                                    ? "bg-red-100 text-red-600"
                                    : "bg-soft-blue/10 text-soft-blue";

                                <tr>
                                    <td class="px-5 py-4 font-bold text-gray-900">@item.BookTitle</td>
                                    <td class="px-5 py-4">@(item.BorrowDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                                    <td class="px-5 py-4">@(item.DueDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                                    <td class="px-5 py-4">
                                        <span class="inline-flex rounded-full px-3 py-1 text-xs font-bold @badgeClass">@item.BorrowStatus</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }
}
