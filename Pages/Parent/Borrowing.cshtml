@page
@model Group3_SE1902_PRN222_LibraryManagement.Pages.Parent.BorrowingModel
@{
    ViewData["Title"] = "Sách đang mượn";
    Layout = "~/Pages/Shared/_ParentLayout.cshtml";
    ViewData["ParentId"] = Model.ParentUserId;
    ViewData["UnreadCount"] = Model.UnreadNotificationsCount;
}

<div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4">
    <div>
        <h1 class="text-3xl font-bold text-slate-800">Sách Đang Mượn</h1>
        <p class="text-slate-500 mt-1">Danh sách những cuốn sách các con chưa trả lại thư viện.</p>
    </div>
    
    @if (Model.Children.Count > 1)
    {
        <form method="get" class="flex items-center gap-3">
            <label class="font-medium text-slate-700 whitespace-nowrap">Lọc theo con:</label>
            <select name="studentId" onchange="this.form.submit()" class="form-select rounded-xl-friendly border-slate-200 text-slate-700 bg-white focus:ring-soft-blue focus:border-soft-blue">
                <option value="">-- Tất cả --</option>
                @foreach (var child in Model.Children)
                {
                    if (Model.SelectedStudentId == child.StudentId)
                    {
                        <option value="@child.StudentId" selected>@child.StudentName</option>
                    }
                    else
                    {
                        <option value="@child.StudentId">@child.StudentName</option>
                    }
                }
            </select>
        </form>
    }
</div>

<div class="bg-white rounded-2xl-friendly shadow-sm border border-slate-100 overflow-hidden">
    @if (Model.BorrowRecords.Any())
    {
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 text-slate-500 text-sm font-semibold border-b border-slate-100">
                        <th class="p-4 rounded-tl-2xl-friendly">Học Sinh</th>
                        <th class="p-4">Tên Sách</th>
                        <th class="p-4">Ngày Mượn</th>
                        <th class="p-4">Hạn Trả</th>
                        <th class="p-4 rounded-tr-2xl-friendly">Trạng Thái</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-sm">
                    @foreach (var record in Model.BorrowRecords)
                    {
                        bool isOverdue = record.DueDate < DateTime.Now;
                        <tr class="hover:bg-slate-50/50 transition-colors">
                            <td class="p-4 font-medium text-slate-800">@record.StudentName</td>
                            <td class="p-4 text-soft-blue font-bold">@record.BookTitle</td>
                            <td class="p-4 text-slate-500">@record.BorrowDate?.ToString("dd/MM/yyyy")</td>
                            <td class="p-4 text-slate-800 font-medium">@record.DueDate?.ToString("dd/MM/yyyy")</td>
                            <td class="p-4">
                                @if (isOverdue)
                                {
                                    <span class="inline-flex px-3 py-1 bg-red-100 text-red-600 font-bold rounded-full text-xs">Quá hạn</span>
                                }
                                else
                                {
                                    <span class="inline-flex px-3 py-1 bg-sunny-yellow/20 text-yellow-700 font-bold rounded-full text-xs">Đang mượn</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="p-16 text-center text-slate-400">
            <svg class="w-16 h-16 mx-auto mb-4 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18 18.246 18.477 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
            <p class="text-lg font-medium">Hiện không có cuốn sách nào đang được mượn.</p>
        </div>
    }
</div>
