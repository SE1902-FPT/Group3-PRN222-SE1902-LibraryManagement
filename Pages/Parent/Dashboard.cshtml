@page
@model Group3_SE1902_PRN222_LibraryManagement.Pages.Parent.DashboardModel

@{
    ViewData["Title"] = "Dashboard phụ huynh";
    Layout = "_ParentLayout";
}

<section class="relative bg-sunny-yellow rounded-2xl-friendly overflow-hidden p-8 md:p-12 lg:p-16 flex flex-col lg:flex-row items-center gap-8 parent-glow">
    <div class="absolute top-0 right-0 -mr-20 -mt-20 w-64 h-64 bg-yellow-300 rounded-full opacity-50 blur-3xl"></div>
    <div class="relative z-10 w-full lg:w-2/3 space-y-5 text-center lg:text-left">
        <span class="inline-flex items-center gap-2 rounded-full bg-white/70 px-4 py-2 text-xs font-bold uppercase tracking-[0.3em] text-gray-700">Dashboard phụ huynh</span>
        <h1 class="text-3xl md:text-5xl font-extrabold text-gray-900 leading-tight">
            Theo dõi việc mượn sách của <span class="text-soft-orange">con thật dễ dàng</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-800 opacity-90">
            Xem nhanh số sách đang mượn, tổng lượt mượn và thông báo mới theo từng con trong cùng một màn hình thân thiện.
        </p>
    </div>
    <div class="relative z-10 w-full lg:w-1/3 grid grid-cols-2 gap-4">
        <div class="rounded-2xl-friendly bg-white/85 p-5 shadow-lg">
            <div class="text-xs font-bold uppercase tracking-[0.25em] text-gray-400">Số con liên kết</div>
            <div class="mt-3 text-4xl font-extrabold text-soft-blue">@Model.StudentOptions.Count</div>
        </div>
        <div class="rounded-2xl-friendly bg-gray-900 p-5 shadow-lg text-white">
            <div class="text-xs font-bold uppercase tracking-[0.25em] text-white/60">Chưa đọc</div>
            <div class="mt-3 text-4xl font-extrabold" data-unread-count>@Model.UnreadNotificationCount</div>
        </div>
    </div>
</section>

@if (Model.StudentOptions.Count == 0)
{
    <section class="bg-white rounded-2xl-friendly p-8 shadow-xl text-center">
        <div class="text-5xl mb-4">👨‍👩‍👧‍👦</div>
        <h2 class="text-2xl font-bold text-gray-900 mb-3">Chưa có học sinh được liên kết</h2>
        <p class="text-gray-500 max-w-2xl mx-auto">Tài khoản phụ huynh này chưa có dữ liệu trong bảng <code>ParentStudent</code>.</p>
    </section>
}
else
{
    <section class="bg-white rounded-2xl-friendly p-6 md:p-8 shadow-xl">
        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-4 mb-6">
            <div>
                <h2 class="text-2xl font-bold text-gray-900 mb-2">Chọn học sinh để xem dữ liệu</h2>
                <p class="text-gray-500">
                    @if (Model.RequiresStudentSelection)
                    {
                        <span>Tài khoản này có nhiều con, vui lòng chọn một học sinh trước khi tải dashboard.</span>
                    }
                    else
                    {
                        <span>Hệ thống đã tự động chọn học sinh duy nhất được liên kết.</span>
                    }
                </p>
            </div>
            <div class="inline-flex items-center rounded-full bg-soft-blue/10 px-4 py-2 text-sm font-bold text-soft-blue">
                Chỉ hiển thị dữ liệu thuộc quyền phụ huynh
            </div>
        </div>

        <form method="get" class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_320px]">
            <div>
                <label class="mb-3 block text-sm font-bold text-gray-700" for="studentId">Học sinh</label>
                <div class="relative">
                    <select class="w-full rounded-full border-2 border-gray-100 bg-white px-5 py-4 text-base font-medium text-gray-800 focus:border-sunny-yellow focus:ring-0" id="studentId" name="studentId" onchange="this.form.submit()">
                        @if (Model.RequiresStudentSelection)
                        {
                            <option value="">Chọn học sinh để xem dashboard</option>
                        }
                        @foreach (var student in Model.StudentOptions)
                        {
                            var selected = Model.SelectedStudent?.StudentId == student.StudentId;
                            <option value="@student.StudentId" selected="@selected">
                                @student.StudentName@(string.IsNullOrWhiteSpace(student.Relationship) ? string.Empty : $" - {student.Relationship}")
                            </option>
                        }
                    </select>
                </div>
            </div>
            <div class="rounded-2xl-friendly bg-gray-50 p-5 border border-gray-100">
                @if (Model.SelectedStudent != null)
                {
                    <div class="text-xs font-bold uppercase tracking-[0.25em] text-gray-400 mb-2">Đang xem</div>
                    <div class="text-xl font-bold text-gray-900">@Model.SelectedStudent.StudentName</div>
                    @if (!string.IsNullOrWhiteSpace(Model.SelectedStudent.Relationship))
                    {
                        <div class="mt-2 text-gray-500">Quan hệ: @Model.SelectedStudent.Relationship</div>
                    }
                }
                else
                {
                    <div class="text-gray-500">Hãy chọn một học sinh để hiển thị dữ liệu.</div>
                }
            </div>
        </form>
    </section>

    @if (Model.RequiresStudentSelection && Model.SelectedStudent == null)
    {
        <section class="bg-white rounded-2xl-friendly p-8 shadow-xl text-center">
            <div class="text-5xl mb-4">📚</div>
            <h2 class="text-2xl font-bold text-gray-900 mb-3">Chưa chọn học sinh</h2>
            <p class="text-gray-500 max-w-2xl mx-auto">Chọn một con trong danh sách phía trên để xem sách đang mượn, lịch sử và thông báo liên quan.</p>
        </section>
    }
    else if (Model.SelectedStudent != null && Model.Summary != null)
    {
        <section class="bg-white rounded-2xl-friendly p-6 md:p-8 shadow-xl">
            <div class="flex flex-col xl:flex-row xl:items-center xl:justify-between gap-4 mb-8">
                <div>
                    <div class="inline-flex items-center rounded-full bg-fresh-green/15 px-4 py-2 text-xs font-bold uppercase tracking-[0.25em] text-fresh-green mb-3">Học sinh đang xem</div>
                    <h2 class="text-3xl font-bold text-gray-900 mb-2">@Model.SelectedStudent.StudentName</h2>
                    <p class="text-gray-500">Tổng hợp nhanh tình hình mượn sách hiện tại của con.</p>
                </div>
                <div class="flex flex-wrap gap-3">
                    <a class="inline-flex items-center justify-center rounded-full bg-gray-100 px-5 py-3 text-sm font-bold text-gray-700 transition hover:bg-sunny-yellow" asp-page="/Parent/BorrowedBooks" asp-route-studentId="@Model.SelectedStudent.StudentId">Sách đang mượn</a>
                    <a class="inline-flex items-center justify-center rounded-full bg-gray-100 px-5 py-3 text-sm font-bold text-gray-700 transition hover:bg-sunny-yellow" asp-page="/Parent/History" asp-route-studentId="@Model.SelectedStudent.StudentId">Lịch sử mượn</a>
                    <a class="inline-flex items-center justify-center rounded-full bg-gray-900 px-5 py-3 text-sm font-bold text-white shadow-lg transition hover:bg-gray-800" asp-page="/Parent/Notifications">Thông báo</a>
                </div>
            </div>

            <div class="grid gap-4 md:grid-cols-3">
                <div class="rounded-2xl-friendly bg-soft-blue/10 p-6">
                    <div class="text-xs font-bold uppercase tracking-[0.25em] text-soft-blue">Sách đang mượn</div>
                    <div class="mt-3 text-4xl font-extrabold text-soft-blue">@Model.Summary.CurrentBorrowedCount</div>
                    <p class="mt-3 text-sm text-gray-500">Các bản sách chưa có <code>ReturnDate</code>.</p>
                </div>
                <div class="rounded-2xl-friendly bg-sunny-yellow/30 p-6">
                    <div class="text-xs font-bold uppercase tracking-[0.25em] text-gray-600">Tổng lượt mượn</div>
                    <div class="mt-3 text-4xl font-extrabold text-soft-orange">@Model.Summary.TotalBorrowCount</div>
                    <p class="mt-3 text-sm text-gray-500">Toàn bộ lịch sử mượn của học sinh này.</p>
                </div>
                <div class="rounded-2xl-friendly bg-fresh-green/15 p-6">
                    <div class="text-xs font-bold uppercase tracking-[0.25em] text-fresh-green">Thông báo chưa đọc</div>
                    <div class="mt-3 text-4xl font-extrabold text-fresh-green" data-unread-count>@Model.Summary.UnreadNotificationCount</div>
                    <p class="mt-3 text-sm text-gray-500">Tổng số thông báo mới của phụ huynh.</p>
                </div>
            </div>
        </section>

        <section class="bg-white rounded-2xl-friendly p-6 md:p-8 shadow-xl">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3 mb-6">
                <div>
                    <h3 class="text-2xl font-bold text-gray-900 mb-2">Sách con đang giữ</h3>
                    <p class="text-gray-500">Danh sách ngắn các sách đang mượn để phụ huynh theo dõi nhanh.</p>
                </div>
                <a class="text-soft-orange font-bold hover:underline" asp-page="/Parent/BorrowedBooks" asp-route-studentId="@Model.SelectedStudent.StudentId">Xem đầy đủ →</a>
            </div>

            @if (Model.CurrentBorrowedBooks.Count == 0)
            {
                <div class="rounded-2xl-friendly bg-gray-50 px-6 py-10 text-center text-gray-500">
                    Hiện tại học sinh này không có sách nào đang mượn.
                </div>
            }
            else
            {
                <div class="overflow-x-auto rounded-2xl border border-gray-100">
                    <table class="min-w-full divide-y divide-gray-100">
                        <thead class="bg-gray-50">
                            <tr class="text-left text-sm font-bold text-gray-600">
                                <th class="px-5 py-4">Tên sách</th>
                                <th class="px-5 py-4">Ngày mượn</th>
                                <th class="px-5 py-4">Hạn trả</th>
                                <th class="px-5 py-4">Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100 bg-white text-sm text-gray-700">
                            @foreach (var item in Model.CurrentBorrowedBooks)
                            {
                                var badgeClass = item.BorrowStatus == "Quá hạn"
                                    ? "bg-red-100 text-red-600"
                                    : "bg-soft-blue/10 text-soft-blue";

                                <tr>
                                    <td class="px-5 py-4 font-bold text-gray-900">@item.BookTitle</td>
                                    <td class="px-5 py-4">@(item.BorrowDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                                    <td class="px-5 py-4">@(item.DueDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                                    <td class="px-5 py-4">
                                        <span class="inline-flex rounded-full px-3 py-1 text-xs font-bold @badgeClass">@item.BorrowStatus</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }
}
