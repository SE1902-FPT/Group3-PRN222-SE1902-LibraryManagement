@page
@model Group3_SE1902_PRN222_LibraryManagement.Pages.Parent.NotificationsModel

@{
    ViewData["Title"] = "Thông báo";
    Layout = "_ParentLayout";
}

<section class="relative bg-fresh-green rounded-2xl-friendly overflow-hidden p-8 md:p-12 flex flex-col lg:flex-row items-center gap-8 text-white">
    <div class="absolute -top-16 -right-10 h-56 w-56 rounded-full bg-white/15 blur-3xl"></div>
    <div class="relative z-10 w-full lg:w-2/3 space-y-5 text-center lg:text-left">
        <span class="inline-flex items-center gap-2 rounded-full bg-white/15 px-4 py-2 text-xs font-bold uppercase tracking-[0.3em] text-white">Lịch sử thông báo</span>
        <h1 class="text-3xl md:text-5xl font-extrabold leading-tight">Thông báo phụ huynh</h1>
        <p class="text-lg text-white/85">Bao gồm thông báo mượn sách, trả sách và quá hạn đã được lưu trong hệ thống.</p>
    </div>
    <div class="relative z-10 w-full lg:w-1/3">
        <div class="rounded-2xl-friendly bg-white/15 p-6 backdrop-blur-sm">
            <div class="text-xs font-bold uppercase tracking-[0.25em] text-white/70">Chưa đọc</div>
            <div class="mt-3 text-4xl font-extrabold" data-unread-count>@Model.UnreadNotificationCount</div>
        </div>
    </div>
</section>

<section class="bg-white rounded-2xl-friendly p-6 md:p-8 shadow-xl">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3 mb-6">
        <div>
            <h2 class="text-2xl font-bold text-gray-900 mb-2">Danh sách thông báo</h2>
            <p class="text-gray-500">Tất cả thông báo đều được lưu để phụ huynh có thể xem lại sau khi đăng nhập.</p>
        </div>
        <a class="text-soft-orange font-bold hover:underline" asp-page="/Parent/Dashboard">Về dashboard →</a>
    </div>

    @if (Model.NotificationItems.Count == 0)
    {
        <div class="rounded-2xl-friendly bg-gray-50 px-6 py-10 text-center text-gray-500" data-parent-notification-empty>
            Chưa có thông báo nào cho tài khoản này.
        </div>
    }

    <div class="space-y-4" data-parent-notification-list>
        @foreach (var notification in Model.NotificationItems)
        {
            var cardClass = notification.IsRead
                ? "bg-white border border-gray-100"
                : "bg-sunny-yellow/10 border border-sunny-yellow/30";
            var badgeClass = notification.IsRead
                ? "bg-gray-100 text-gray-600"
                : "bg-soft-orange text-white";

            <article class="rounded-2xl-friendly p-5 shadow-sm @cardClass">
                <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-4">
                    <div class="flex-1">
                        <div class="flex flex-wrap items-center gap-2 mb-3">
                            <span class="inline-flex rounded-full px-3 py-1 text-xs font-bold @badgeClass">@(notification.IsRead ? "Đã đọc" : "Chưa đọc")</span>
                            <span class="text-sm text-gray-400">@(notification.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</span>
                        </div>
                        <p class="text-base leading-7 text-gray-700">@notification.Message</p>
                    </div>

                    @if (!notification.IsRead)
                    {
                        <form method="post" asp-page-handler="MarkAsRead" class="m-0">
                            <input type="hidden" name="notificationId" value="@notification.NotificationId" />
                            <button type="submit" class="inline-flex items-center justify-center rounded-full bg-gray-900 px-5 py-3 text-sm font-bold text-white shadow-lg transition hover:bg-gray-800">
                                Đánh dấu đã đọc
                            </button>
                        </form>
                    }
                </div>
            </article>
        }
    </div>
</section>
