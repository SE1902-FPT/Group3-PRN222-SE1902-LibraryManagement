@page
@model Group3_SE1902_PRN222_LibraryManagement.Pages.SearchModel
@{
    ViewData["Title"] = "Search Sách";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'sunny-yellow': '#FFD93D',
                        'soft-orange': '#FF8400',
                        'fresh-green': '#6BCB77',
                        'soft-blue': '#4D96FF',
                    },
                    fontFamily: {
                        sans: ['Lexend', 'sans-serif'],
                    },
                    borderRadius: {
                        'xl-friendly': '24px',
                        '2xl-friendly': '32px',
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #FFFDF5;
        }
    </style>
</head>
<body class="antialiased text-gray-800">
    <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100 px-6 py-4">
        <div class="max-w-7xl mx-auto flex items-center justify-between gap-4">
            <a class="flex items-center gap-2 shrink-0" href="/">
                <div class="bg-sunny-yellow p-2 rounded-xl-friendly">
                    <svg class="h-8 w-8 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18 18.246 18.477 16.5 18c-1.746 0-3.332.477-4.5 1.253" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                </div>
                <span class="font-bold text-xl tracking-tight hidden md:block">Thư Viện Nhí</span>
            </a>

            <form class="flex-grow max-w-2xl grid gap-3 md:grid-cols-[2fr,1fr,1fr,auto]" method="get">
                <div class="relative">
                    <svg class="absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                    </svg>
                    <input class="w-full pl-12 pr-4 py-3 rounded-full md:rounded-xl-friendly border-2 border-gray-100 focus:border-sunny-yellow focus:ring-0 text-sm md:text-base" name="search" placeholder="Tìm sách, tác giả, nhà xuất bản..." type="text" value="@Model.SearchTerm" />
                </div>
                <select class="px-4 py-3 rounded-full md:rounded-xl-friendly border-2 border-gray-100 focus:border-sunny-yellow focus:ring-0 text-sm" name="categoryId">
                    <option value="">Tất cả thể loại</option>
                    @foreach (var category in Model.Categories)
                    {
                        if (Model.SelectedCategoryId == category.CategoryId)
                        {
                            <option selected value="@category.CategoryId">@category.CategoryName</option>
                        }
                        else
                        {
                            <option value="@category.CategoryId">@category.CategoryName</option>
                        }
                    }
                </select>
                <select class="px-4 py-3 rounded-full md:rounded-xl-friendly border-2 border-gray-100 focus:border-sunny-yellow focus:ring-0 text-sm" name="availability">
                    @if (Model.Availability == "available")
                    {
                        <option value="all">Tất cả trạng thái</option>
                        <option selected value="available">Còn sách</option>
                    }
                    else
                    {
                        <option selected value="all">Tất cả trạng thái</option>
                        <option value="available">Còn sách</option>
                    }
                </select>
                <button class="px-5 py-3 bg-gray-900 text-white text-sm font-bold rounded-full md:rounded-xl-friendly hover:bg-soft-orange transition-colors" type="submit">
                    Search
                </button>
            </form>

            <div class="flex items-center gap-3">
                @if (!Model.IsAuthenticated)
                {
                    <a class="px-4 py-2 text-sm font-semibold rounded-full border border-soft-blue bg-white text-soft-blue hover:bg-soft-blue hover:text-white transition" href="/Login">Đăng nhập</a>
                }
                <div class="relative" id="profile-wrapper">
                    <button id="profile-btn" class="flex items-center gap-3 bg-gray-50 px-3 py-1.5 rounded-full border border-gray-100 hover:border-sunny-yellow transition-colors">
                        <div class="text-right hidden sm:block">
                            <div class="text-sm font-bold leading-none">@(Model.CurrentUser?.FullName ?? "Khách")</div>
                            <div class="text-[10px] text-gray-500 font-medium tracking-wider uppercase">Lớp @Model.UserClassName</div>
                        </div>
                    <div class="w-10 h-10 rounded-full bg-soft-orange border-2 border-white overflow-hidden">
                        <img alt="Avatar" class="w-full h-full object-cover" src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.CurrentUser?.FullName ?? "U")&background=FF8400&color=fff" />
                    </div>
                </button>

                <div id="profile-dropdown" class="absolute right-0 mt-2 w-64 bg-white rounded-2xl shadow-xl border border-gray-100 hidden z-50 overflow-hidden">
                    <div class="px-4 py-4 bg-gradient-to-r from-sunny-yellow/30 to-soft-orange/20 border-b border-gray-100">
                        <p class="font-bold text-sm">@(Model.CurrentUser?.FullName ?? "Khách")</p>
                        <p class="text-xs text-gray-500 mt-1">Lớp @Model.UserClassName</p>
                    </div>
                    <div class="p-2 space-y-2">
                        @if (Model.IsAuthenticated)
                        {
                            <a class="flex items-center justify-between px-3 py-3 rounded-xl hover:bg-gray-50 transition-colors" href="/Student/FavoriteBooks">
                                <span class="flex items-center gap-3 text-sm font-medium text-gray-700">
                                    <svg class="h-5 w-5 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0"></path>
                                    </svg>
                                    Danh sách yêu thích
                                </span>
                                <span class="text-xs font-bold text-soft-orange">@Model.FavoriteCount</span>
                            </a>
                        }
                        <a class="flex items-center gap-3 px-3 py-3 rounded-xl hover:bg-gray-50 transition-colors text-sm font-medium text-gray-700" href="/">
                            <svg class="h-5 w-5 text-soft-blue" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" stroke-linecap="round" stroke-linejoin="round"></path>
                            </svg>
                            Trang Home
                        </a>
                        @if (Model.IsAuthenticated)
                        {
                            <a class="flex items-center gap-3 px-3 py-3 rounded-xl hover:bg-red-50 transition-colors text-sm font-medium text-red-500" href="/Logout">
                                <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" stroke-linecap="round" stroke-linejoin="round"></path>
                                </svg>
                                Logout
                            </a>
                        }
                        else
                        {
                            <p class="text-xs text-gray-500">Đăng nhập để lưu sách yêu thích và quản lý danh sách của bạn.</p>
                            <a class="flex items-center gap-3 px-3 py-3 rounded-xl hover:bg-soft-blue/10 transition-colors text-sm font-medium text-soft-blue" href="/Login">
                                <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                    <path d="M15 12H3m9 0l-3-3m3 3l-3 3m8-9v12a2 2 0 01-2 2H7a2 2 0 01-2-2V7a2 2 0 012-2h6" stroke-linecap="round" stroke-linejoin="round"></path>
                                </svg>
                                Đăng nhập</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-6 py-10">
        <section class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-8">
            <div>
                <p class="text-sm font-bold uppercase tracking-[0.25em] text-soft-orange mb-2">Trang Search Riêng</p>
                <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900">Tìm kiếm sách nhanh hơn</h1>
                <p class="text-gray-500 mt-2">Kết quả được lọc theo từ khóa, thể loại và tình trạng còn sách.</p>
            </div>
            <div class="flex gap-3">
                <a class="px-5 py-3 bg-white border border-gray-200 text-gray-700 font-bold rounded-xl-friendly hover:bg-gray-50 transition-colors" href="/">
                    Về Home
                </a>
                <a class="px-5 py-3 bg-sunny-yellow text-gray-900 font-bold rounded-xl-friendly hover:bg-yellow-300 transition-colors" href="/Student/FavoriteBooks">
                    Favorite
                </a>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(Model.SearchTerm) || Model.SelectedCategoryId.HasValue || Model.Availability == "available")
        {
            <section class="mb-8 flex flex-wrap gap-3">
                @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
                {
                    <span class="px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-full">Từ khóa: @Model.SearchTerm</span>
                }
                @if (Model.SelectedCategoryId.HasValue)
                {
                    var selectedCategory = Model.Categories.FirstOrDefault(c => c.CategoryId == Model.SelectedCategoryId.Value)?.CategoryName;
                    <span class="px-4 py-2 bg-soft-blue/10 text-soft-blue text-sm font-medium rounded-full">Thể loại: @selectedCategory</span>
                }
                @if (Model.Availability == "available")
                {
                    <span class="px-4 py-2 bg-fresh-green/10 text-fresh-green text-sm font-medium rounded-full">Chỉ hiện sách còn sẵn</span>
                }
            </section>
        }

        <section class="mb-8 bg-white rounded-2xl-friendly border border-gray-100 p-5 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div>
                <p class="text-sm text-gray-500">Tổng kết quả</p>
                <p class="text-3xl font-black text-gray-900">@Model.Books.Count</p>
            </div>
            <div class="grid grid-cols-2 md:grid-cols-3 gap-3 text-sm">
                <div class="px-4 py-3 bg-gray-50 rounded-xl">
                    <p class="text-gray-400">Còn sách</p>
                    <p class="font-bold text-fresh-green">@Model.Books.Count(b => b.BookCopies.Any(c => c.Status == "Available"))</p>
                </div>
                <div class="px-4 py-3 bg-gray-50 rounded-xl">
                    <p class="text-gray-400">Yêu thích</p>
                    <p class="font-bold text-soft-orange">@Model.FavoriteCount</p>
                </div>
                <div class="px-4 py-3 bg-gray-50 rounded-xl col-span-2 md:col-span-1">
                    <p class="text-gray-400">Thể loại</p>
                    <p class="font-bold text-soft-blue">@Model.Categories.Count</p>
                </div>
            </div>
        </section>

        @if (Model.Books.Any())
        {
            <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                @foreach (var book in Model.Books)
                {
                    var availableCopies = book.BookCopies.Count(c => c.Status == "Available");
                    <article class="bg-white rounded-2xl-friendly shadow-sm hover:shadow-xl transition-shadow overflow-hidden flex flex-col border border-gray-100">
                        <div class="aspect-[3/4] bg-gray-100 relative overflow-hidden">
                            @if (Model.FavoriteBookIds.Contains(book.BookId))
                            {
                                <span class="absolute top-3 right-3 z-10 bg-white/95 text-red-500 text-xs font-bold px-3 py-1 rounded-full">Favorite</span>
                            }
                            <img alt="@book.Title" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" src="https://images.unsplash.com/photo-1544648151-0738d38e67f7?auto=format&fit=crop&q=80&w=400" />
                            @if (book.Category != null)
                            {
                                <div class="absolute bottom-3 left-3 bg-soft-blue text-white text-xs font-bold px-2 py-1 rounded-full">
                                    @book.Category.CategoryName
                                </div>
                            }
                        </div>
                        <div class="p-4 flex flex-col flex-1">
                            <h2 class="font-bold text-base mb-1 leading-snug">@book.Title</h2>
                            <p class="text-gray-500 text-sm">@book.Author</p>
                            <p class="text-gray-400 text-xs mt-1">NXB: @(book.Publisher ?? "Đang cập nhật")</p>
                            <div class="mt-4 flex items-center justify-between gap-3">
                                <span class="text-sm font-bold @(availableCopies > 0 ? "text-fresh-green" : "text-red-500")">
                                    @(availableCopies > 0 ? $"Còn {availableCopies} bản" : "Hết sách")
                                </span>
                                <span class="text-xs text-gray-400">ID #@book.BookId</span>
                            </div>
                            <a class="mt-4 w-full py-2.5 text-center bg-gray-100 hover:bg-sunny-yellow text-gray-700 font-bold rounded-xl transition-colors block" href="/Books/Details?id=@book.BookId">
                                Xem chi tiết
                            </a>
                        </div>
                    </article>
                }
            </section>
        }
        else
        {
            <section class="bg-white border border-dashed border-gray-200 rounded-2xl-friendly p-16 text-center">
                <h2 class="text-2xl font-bold text-gray-800">Không tìm thấy sách phù hợp</h2>
                <p class="text-gray-500 mt-3">Thử đổi từ khóa hoặc nới bộ lọc để xem thêm kết quả.</p>
                <div class="mt-6 flex justify-center gap-3">
                    <a class="px-5 py-3 bg-gray-900 text-white font-bold rounded-xl-friendly hover:bg-soft-orange transition-colors" href="/Search">
                        Xóa filter
                    </a>
                    <a class="px-5 py-3 bg-gray-100 text-gray-700 font-bold rounded-xl-friendly hover:bg-gray-200 transition-colors" href="/">
                        Về Home
                    </a>
                </div>
            </section>
        }
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const profileBtn = document.getElementById('profile-btn');
            const profileDropdown = document.getElementById('profile-dropdown');

            profileBtn.addEventListener('click', function (e) {
                e.stopPropagation();
                profileDropdown.classList.toggle('hidden');
            });

            document.addEventListener('click', function (e) {
                if (!profileBtn.contains(e.target) && !profileDropdown.contains(e.target)) {
                    profileDropdown.classList.add('hidden');
                }
            });
        });
    </script>
</body>
</html>
