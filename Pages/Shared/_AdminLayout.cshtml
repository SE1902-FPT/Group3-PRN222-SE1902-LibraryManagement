<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Library Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #f8f9fa;
        }

        #wrapper {
            display: flex;
            align-items: stretch;
        }

        #sidebar {
            min-width: 250px;
            max-width: 250px;
            min-height: 100vh;
            background: #212529;
            color: #fff;
            transition: all 0.3s;
        }

            #sidebar.active {
                margin-left: -250px;
            }

            #sidebar .sidebar-header {
                padding: 20px;
                background: #1a1d20;
                text-align: center;
                border-bottom: 1px solid #343a40;
            }

            #sidebar ul li a {
                padding: 15px 20px;
                display: block;
                color: #ced4da;
                text-decoration: none;
                transition: 0.2s;
            }

                #sidebar ul li a:hover {
                    background: #343a40;
                    color: #fff;
                }

                #sidebar ul li a.active {
                    background: #0d6efd;
                    color: #fff;
                }

        #content {
            width: 100%;
            padding: 20px;
        }

        .img-thumbnail-custom {
            width: 70px;
            height: 100px;
            object-fit: cover;
            border-radius: 5px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        }
    </style>
</head>
<body>
    <div id="wrapper">
        <nav id="sidebar">
            <div class="sidebar-header">
                <h5 class="m-0">Library Admin</h5>
            </div>
            <ul class="list-unstyled mt-3">
                <li><a asp-page="/Admin/Index"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a></li>
                <li><a asp-page="/Admin/BookManagement/Index" class="active"><i class="bi bi-book me-2"></i> Books</a></li>
                <li><a asp-page="/Admin/CategoryManagement/Index"><i class="bi bi-tags me-2"></i> Categories</a></li>
                <li><a asp-page="/Admin/UserManagement/Index"><i class="bi bi-people me-2"></i> Users</a></li>
                <li class="border-top mt-3"><a asp-page="/Index" class="text-warning"><i class="bi bi-arrow-left-circle me-2"></i> View Website</a></li>
            </ul>
        </nav>

        <div id="content">
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom mb-4 shadow-sm">
                <div class="container-fluid">
                    <button type="button" id="sidebarCollapse" class="btn btn-outline-dark btn-sm">
                        <i class="bi bi-list"></i>
                    </button>
                    <span class="ms-3 fw-bold text-uppercase">@ViewData["Title"]</span>
                </div>
            </nav>

            <div class="card shadow-sm border-0">
                <div class="card-body">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#sidebarCollapse').on('click', function () {
                $('#sidebar').toggleClass('active');
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>