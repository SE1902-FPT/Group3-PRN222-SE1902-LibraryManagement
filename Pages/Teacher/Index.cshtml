@page "/TeacherDashboard"
@model Group3_SE1902_PRN222_LibraryManagement.Pages.Teacher.IndexModel
@{
    ViewData["Title"] = "Trang Giáo Viên";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"]</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'sunny-yellow': '#FFD93D',
                        'soft-orange': '#FF8400',
                        'fresh-green': '#6BCB77',
                        'soft-blue': '#4D96FF',
                    },
                    fontFamily: {
                        sans: ['Lexend', 'sans-serif'],
                    },
                    borderRadius: {
                        'xl-friendly': '24px',
                        '2xl-friendly': '32px',
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #FFFDF5;
        }
    </style>
</head>
<body class="antialiased text-gray-800">
    <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-100 px-6 py-4">
        <div class="max-w-7xl mx-auto flex items-center justify-between gap-4">
            <div class="flex items-center gap-3">
                <div class="bg-soft-blue p-2 rounded-xl-friendly">
                    <svg class="h-8 w-8 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"></path>
                    </svg>
                </div>
                <div>
                    <h1 class="font-bold text-xl">Trang giáo viên</h1>
                    <p class="text-sm text-gray-500">@Model.CurrentTeacher?.FullName</p>
                </div>
            </div>
            <div class="flex items-center gap-3">
                <a href="/TeacherRecommendations" class="px-4 py-2 bg-white border border-gray-200 rounded-xl-friendly font-medium hover:bg-gray-50 transition-colors">
                    Xem trang đề xuất
                </a>
                <a href="/Logout" class="px-4 py-2 bg-gray-900 text-white rounded-xl-friendly font-medium hover:bg-soft-orange transition-colors">
                    Logout
                </a>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto px-6 py-10 space-y-8">
        <section class="bg-white rounded-2xl-friendly border border-gray-100 shadow-sm p-6 md:p-8">
            <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6">
                <div>
                    <p class="text-sm font-bold uppercase tracking-[0.2em] text-soft-blue mb-2">Teacher Tools</p>
                    <h2 class="text-3xl font-extrabold text-gray-900">Xem sách và đề xuất cho học sinh</h2>
                    <p class="text-gray-500 mt-2">Giáo viên có thể duyệt danh sách sách và đánh dấu các cuốn nên đọc cho học sinh.</p>
                </div>
                <div class="flex flex-wrap gap-3">
                    @foreach (var cls in Model.TeachingClasses)
                    {
                        <span class="px-4 py-2 bg-soft-blue/10 text-soft-blue rounded-full text-sm font-bold">@cls.ClassName</span>
                    }
                    @if (!Model.TeachingClasses.Any())
                    {
                        <span class="px-4 py-2 bg-gray-100 text-gray-600 rounded-full text-sm font-medium">Chưa gán lớp</span>
                    }
                </div>
            </div>
        </section>

        @if (TempData["Message"] != null)
        {
            var isSuccess = TempData["MessageType"]?.ToString() == "success";
            <section class="px-5 py-4 rounded-2xl-friendly border @(isSuccess ? "bg-green-50 border-green-200 text-green-800" : "bg-red-50 border-red-200 text-red-800")">
                <p class="font-medium">@TempData["Message"]</p>
            </section>
        }

        <section class="bg-white rounded-2xl-friendly border border-gray-100 p-6">
            <form method="get" class="grid gap-4 md:grid-cols-[2fr,1fr,auto]">
                <div class="relative">
                    <svg class="absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"></path>
                    </svg>
                    <input type="text" name="search" value="@Model.SearchTerm" placeholder="Tìm theo tên sách, tác giả, ISBN..." class="w-full pl-12 pr-4 py-3 rounded-xl-friendly border border-gray-200 focus:ring-soft-blue focus:border-soft-blue" />
                </div>
                <select name="categoryId" class="px-4 py-3 rounded-xl-friendly border border-gray-200 focus:ring-soft-blue focus:border-soft-blue">
                    <option value="">Tất cả thể loại</option>
                    @foreach (var category in Model.Categories)
                    {
                        if (Model.SelectedCategoryId == category.CategoryId)
                        {
                            <option selected value="@category.CategoryId">@category.CategoryName</option>
                        }
                        else
                        {
                            <option value="@category.CategoryId">@category.CategoryName</option>
                        }
                    }
                </select>
                <button type="submit" class="px-6 py-3 bg-soft-blue text-white font-bold rounded-xl-friendly hover:bg-blue-500 transition-colors">
                    Lọc sách
                </button>
            </form>
        </section>

        <section class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            @foreach (var book in Model.Books)
            {
                var availableCopies = book.BookCopies.Count(c => c.Status == "Available");
                var isRecommended = Model.TeacherRecommendationMap.ContainsKey(book.BookId);
                var recommendation = isRecommended ? Model.TeacherRecommendationMap[book.BookId] : null;

                <article class="bg-white rounded-2xl-friendly border border-gray-100 shadow-sm overflow-hidden">
                    <div class="p-6">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <div class="flex items-center gap-2 flex-wrap mb-2">
                                    <h3 class="text-xl font-bold text-gray-900">@book.Title</h3>
                                    @if (isRecommended)
                                    {
                                        <span class="px-3 py-1 bg-fresh-green text-white text-xs font-bold rounded-full">Đã đề xuất</span>
                                    }
                                </div>
                                <p class="text-gray-500">@book.Author</p>
                                <div class="flex gap-4 mt-3 text-sm text-gray-500 flex-wrap">
                                    <span>Thể loại: <strong class="text-gray-700">@book.Category?.CategoryName</strong></span>
                                    <span>ISBN: <strong class="text-gray-700">@(book.Isbn ?? "N/A")</strong></span>
                                    <span class="@(availableCopies > 0 ? "text-fresh-green" : "text-red-500")">Còn: <strong>@availableCopies/@book.BookCopies.Count</strong></span>
                                </div>
                            </div>
                            <a href="/Books/Details?id=@book.BookId" class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold rounded-xl-friendly transition-colors">
                                Xem sách
                            </a>
                        </div>

                        <form method="post" asp-page-handler="Recommend" class="mt-5 space-y-3">
                            <input type="hidden" name="bookId" value="@book.BookId" />
                            <input type="hidden" name="search" value="@Model.SearchTerm" />
                            <input type="hidden" name="categoryId" value="@(Model.SelectedCategoryId?.ToString() ?? string.Empty)" />
                            <textarea name="RecommendationNote" rows="3" class="w-full px-4 py-3 rounded-xl-friendly border border-gray-200 focus:ring-soft-blue focus:border-soft-blue" placeholder="Ghi chú cho học sinh về cuốn sách này...">@(recommendation?.Note ?? string.Empty)</textarea>
                            <div class="flex gap-3 flex-wrap">
                                <button type="submit" class="px-5 py-3 bg-soft-blue hover:bg-blue-500 text-white font-bold rounded-xl-friendly transition-colors">
                                    @(isRecommended ? "Cập nhật đề xuất" : "Đề xuất cho học sinh")
                                </button>
                                @if (isRecommended && recommendation != null)
                                {
                                    <button type="submit"
                                            asp-page-handler="RemoveRecommendation"
                                            asp-route-recommendationId="@recommendation.RecommendationId"
                                            asp-route-search="@Model.SearchTerm"
                                            asp-route-categoryId="@Model.SelectedCategoryId"
                                            class="px-5 py-3 bg-red-50 hover:bg-red-100 text-red-500 font-bold rounded-xl-friendly transition-colors">
                                        Gỡ đề xuất
                                    </button>
                                }
                            </div>
                        </form>
                    </div>
                </article>
            }
        </section>

        @if (!Model.Books.Any())
        {
            <section class="bg-white rounded-2xl-friendly border border-dashed border-gray-200 p-16 text-center">
                <h2 class="text-2xl font-bold text-gray-800">Không có sách phù hợp</h2>
                <p class="text-gray-500 mt-3">Thử đổi từ khóa hoặc bộ lọc để xem thêm danh sách.</p>
            </section>
        }
    </main>
</body>
</html>
